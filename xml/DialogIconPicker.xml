<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
	<defaultcontrol always="true">3001</defaultcontrol>
	<depth>DepthOSD</depth>
	<include>Animation_DialogPopupOpenClose</include>
	<controls>
		<!-- Backdrop darken + close on click -->
		<control type="image">
			<left>-2000</left>
			<top>-2000</top>
			<width>6000</width>
			<height>6000</height>
			<animation effect="fade" start="0" end="100" time="300">WindowOpen</animation>
			<animation effect="fade" start="100" end="0" time="200">WindowClose</animation>
			<texture colordiffuse="A6FFFFFF">colors/black.png</texture>
		</control>
		<control type="button">
			<left>-2000</left>
			<top>-2000</top>
			<width>6000</width>
			<height>6000</height>
			<texturefocus />
			<texturenofocus />
			<onclick>Action(close)</onclick>
		</control>

		<!-- Main dialog container -->
		<control type="group">
			<centerleft>50%</centerleft>
			<centertop>50%</centertop>
			<width>1085</width>
			<height>730</height>

			<include content="DialogBackgroundCommons">
				<param name="header_label" value="Choose icon" />
				<param name="header_id" value="1" />
				<param name="width" value="1085" />
				<param name="height" value="730" />
				<param name="header_top" value="15" />
				<param name="divider_top" value="90" />
			</include>

			<!-- Background -->
			<!-- <control type="image">
				<left>0</left>
				<top>0</top>
				<right>0</right>
				<bottom>0</bottom>
				<texture colordiffuse="$VAR[DialogBackgroundDiffuse]">$VAR[DialogBackgroundTexture]</texture>
				<aspectratio>scale</aspectratio>
			</control> -->

			<!-- Header label -->
			<!-- <control type="label" id="1">
				<left>30</left>
				<right>30</right>
				<top>17</top>
				<height>50</height>
				<label>Choose icon</label>
				<align>left</align>
				<aligny>center</aligny>
				<font>font36_title</font>
				<textcolor>unfocused_text</textcolor>
			</control> -->

			<!-- Folder list (left side) -->
			<control type="list" id="3001">
				<left>40</left>
				<top>130</top>
				<width>270</width>
				<height>560</height>
				<onup>3001</onup>
				<ondown>3001</ondown>
				<onleft>3001</onleft>
				<onright>3000</onright>
				<pagecontrol>33</pagecontrol>
				<onfocus>RunScript(script.altus.helper,mode=icon_folder_debounce)</onfocus>
				<scrolltime tween="cubic" easing="out">300</scrolltime>
				<itemlayout width="270" height="70">
					<control type="label">
						<left>25</left>
						<right>10</right>
						<font>font32</font>
						<textcolor>unfocused_text</textcolor>
						<label>$INFO[ListItem.Label]</label>
						<aligny>center</aligny>
					</control>
				</itemlayout>
				<focusedlayout width="270" height="70">
					<control type="image">
						<left>0</left>
						<top>0</top>
						<right>0</right>
						<bottom>0</bottom>
						<texture border="23" colordiffuse="$VAR[FocusColorTheme]">masks/radius_23.png</texture>
						<animation effect="fade" start="100" end="50" time="40" condition="!Control.HasFocus(3001)">Conditional</animation>
					</control>
					<control type="label">
						<left>25</left>
						<right>10</right>
						<font>font32</font>
						<textcolor>$VAR[FocusedTextColorVar]</textcolor>
						<label>$INFO[ListItem.Label]</label>
						<aligny>center</aligny>
					</control>
				</focusedlayout>
			</control>

			<!-- Separator -->
			<control type="image">
				<height>560</height>
				<left>350</left>
				<top>130</top>
				<width>1</width>
				<texture colordiffuse="$VAR[FocusColorTheme]">colors/dark.png</texture>
			</control>

			<control type="scrollbar" id="33">
				<height>560</height>
				<left>350</left>
				<top>130</top>
				<width>1</width>
				<orientation>vertical</orientation>
				<texturesliderbackground/>
				<texturesliderbar colordiffuse="$VAR[FocusColorTheme]">colors/white.png</texturesliderbar>
				<texturesliderbarfocus colordiffuse="$VAR[FocusColorTheme]">colors/white.png</texturesliderbarfocus>
				<showonepage>false</showonepage>
			</control>

			<!-- Icon grid panel -->
			<control type="panel" id="3000">
				<left>390</left>
				<top>130</top>
				<width>740</width>
				<bottom>45</bottom>
				<onup>3000</onup>
				<ondown>3000</ondown>
				<onleft>3001</onleft>
				<onright>3000</onright>
				<orientation>vertical</orientation>
				<itemlayout height="110" width="110">
					<control type="group">
						<left>5</left>
						<top>5</top>
						<width>100</width>
						<height>100</height>
						<control type="image">
							<left>25</left>
							<top>25</top>
							<width>50</width>
							<height>50</height>
							<texture diffuse="masks/mainmenu-img.png" colordiffuse="unfocused_text">$INFO[ListItem.Icon]</texture>
							<aspectratio>keep</aspectratio>
						</control>
					</control>
				</itemlayout>
				<focusedlayout height="110" width="110">
					<control type="group">
						<left>5</left>
						<top>5</top>
						<width>100</width>
						<height>100</height>
						<control type="image">
							<left>0</left>
							<top>0</top>
							<width>100</width>
							<height>100</height>
							<texture colordiffuse="$VAR[FocusColorTheme]">masks/mainmenu-img.png</texture>
							<aspectratio>stretch</aspectratio>
						</control>
						<control type="image">
							<left>25</left>
							<top>25</top>
							<width>50</width>
							<height>50</height>
							<texture diffuse="masks/mainmenu-img.png" colordiffuse="$VAR[FocusedTextColorVar]">$INFO[ListItem.Icon]</texture>
							<aspectratio>keep</aspectratio>
						</control>
					</control>
				</focusedlayout>
			</control>

			<!-- Selected icon name -->
			<control type="label">
				<right>40</right>
				<bottom>25</bottom>
				<right>30</right>
				<height>30</height>
				<font>font12</font>
				<align>right</align>
				<textcolor>grey</textcolor>
				<label>$INFO[Container(3000).ListItem.Label]</label>
			</control>
		</control>
	</controls>
</window>
