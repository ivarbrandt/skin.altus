<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<include name="BigLandscapeLayout">
		<param name="focused">false</param>
		<definition>
			<control type="group">
				<visible>String.IsEmpty(ListItem.Art(fanart)) + String.IsEmpty(ListItem.Art(landscape))</visible>
				<control type="image">
					<left>19</left>
					<top>11</top>
					<width>582</width>
					<height>327</height>
					<texture colordiffuse="$VAR[FocusColorTheme]">colors/white.png</texture>
					<visible>[[$PARAM[focused] + Control.HasFocus($PARAM[list_id])] + !Player.HasMedia + String.IsEmpty(Skin.String(TrailerPlaying))] | [[$PARAM[focused] + [Control.IsVisible(55) | Control.IsVisible(501)]] + !Player.HasMedia + String.IsEmpty(Skin.String(TrailerPlaying))]</visible>
					<visible>!Container($PARAM[list_id]).IsUpdating</visible>
					<include condition="$PARAM[focused]">Animation_FocusTextureFade</include>
				</control>
				<control type="textbox">
					<left>333</left>
					<top>40</top>
					<width>222</width>
					<height>262</height>
					<font>font25</font>
					<align>center</align>
					<aligny>center</aligny>
					<label>$INFO[ListItem.Label]</label>
					<textcolor>$VAR[FocusedTextColorVar]</textcolor>
					<autoscroll time="3000" delay="4000" repeat="3000">$PARAM[focused] + Control.HasFocus($PARAM[list_id])</autoscroll>
					<visible>!ListItem.IsParentFolder + [$PARAM[focused] + Control.HasFocus($PARAM[list_id])] | [$PARAM[focused] + [Control.IsVisible(55) | Control.IsVisible(501)]]</visible>
				</control>
				<control type="textbox">
					<left>333</left>
					<top>40</top>
					<width>222</width>
					<height>262</height>
					<font>font25</font>
					<align>center</align>
					<aligny>center</aligny>
					<label>$INFO[ListItem.Label]</label>
					<textcolor>unfocused_text</textcolor>
					<visible>!ListItem.IsParentFolder + [!$PARAM[focused] | [!Control.HasFocus($PARAM[list_id]) + ![Control.IsVisible(55) | Control.IsVisible(501)]]]</visible>
				</control>
				<control type="image">
					<left>30</left>
					<top>35.5</top>
					<width>270</width>
					<height>270</height>
					<texture fallback="DefaultMovies.png" background="true">$VAR[IconWallThumbVar]</texture>
					<aspectratio scalediffuse="false">scale</aspectratio>
					<bordersize>20</bordersize>
					<visible>!ListItem.IsParentFolder + $PARAM[focused] + Control.HasFocus($PARAM[list_id])</visible>
				</control>
				<control type="image">
					<left>30</left>
					<top>35.5</top>
					<width>270</width>
					<height>270</height>
					<texture colordiffuse="unfocused_text" fallback="DefaultMovies.png" background="true">$VAR[IconWallThumbVar]</texture>
					<aspectratio scalediffuse="false">scale</aspectratio>
					<bordersize>20</bordersize>
					<visible>!ListItem.IsParentFolder + ![$PARAM[focused] + Control.HasFocus($PARAM[list_id])]</visible>
				</control>
			</control>
			<control type="group">
				<visible>!String.IsEmpty(ListItem.Art(fanart)) | !String.IsEmpty(ListItem.Art(landscape))</visible>
				<control type="image">
					<left>20</left>
					<top>11</top>
					<width>582</width>
					<height>327</height>
					<texture diffuse="masks/biglandscape.png" colordiffuse="artwork_dim" background="true">$VAR[LandscapeTextureVar]</texture>
					<aspectratio scalediffuse="false">scale</aspectratio>
				</control>
				<control type="group">
					<top>294</top>
					<visible>$EXP[isEpisode]</visible>
					<include content="EpisodeTypeBadge">
						<param name="right" value="-7"/>
						<param name="top" value="-275"/>
					</include>
					<include content="SeasonEpisodeBadge">
						<param name="left" value="64"/>
						<param name="top" value="0"/>
						<param name="vis" value="$EXP[hasWallWatchedIcon] + ![$PARAM[focused] + [Control.HasFocus($PARAM[list_id]) | Control.IsVisible(55) | Control.IsVisible(501)]]"/>
					</include>
					<include content="SeasonEpisodeBadge">
						<param name="left" value="31"/>
						<param name="top" value="0"/>
						<param name="vis" value="!$EXP[hasWallWatchedIcon] + ![$PARAM[focused] + [Control.HasFocus($PARAM[list_id]) | Control.IsVisible(55) | Control.IsVisible(501)]]"/>
					</include>
					<!-- Episode badge: non-season view (with watched icon) -->
					<include content="InfoBadge">
						<param name="left" value="64"/>
						<param name="top" value="1"/>
						<param name="max_width" value="530"/>
						<param name="label" value="[UPPERCASE][LIGHT]$INFO[Container($PARAM[list_id]).ListItem.Season]$INFO[Container($PARAM[list_id]).ListItem.Episode,x,] | $VAR[InfoBadgeSeasonTitle][/UPPERCASE][/LIGHT]"/>
						<param name="vis" value="$EXP[hasWallWatchedIcon] + !String.StartsWith(Container($PARAM[list_id]).PluginCategory,Season)"/>
						<param name="vis2" value="[$PARAM[focused] + Control.HasFocus($PARAM[list_id])] | [$PARAM[focused] + [Control.IsVisible(55) | Control.IsVisible(501)]]"/>
					</include>
					<!-- Episode badge: non-season view (no watched icon, shifted left) -->
					<include content="InfoBadge">
						<param name="left" value="31"/>
						<param name="top" value="1"/>
						<param name="max_width" value="530"/>
						<param name="label" value="[UPPERCASE][LIGHT]$INFO[Container($PARAM[list_id]).ListItem.Season]$INFO[Container($PARAM[list_id]).ListItem.Episode,x,] | $VAR[InfoBadgeSeasonTitle][/UPPERCASE][/LIGHT]"/>
						<param name="vis" value="!$EXP[hasWallWatchedIcon] + !String.StartsWith(Container($PARAM[list_id]).PluginCategory,Season)"/>
						<param name="vis2" value="[$PARAM[focused] + Control.HasFocus($PARAM[list_id])] | [$PARAM[focused] + [Control.IsVisible(55) | Control.IsVisible(501)]]"/>
					</include>
					<!-- Episode badge: season view (with watched icon) -->
					<include content="InfoBadge">
						<param name="left" value="64"/>
						<param name="top" value="1"/>
						<param name="max_width" value="530"/>
						<param name="label" value="$INFO[Container($PARAM[list_id]).ListItem.Season]$INFO[Container($PARAM[list_id]).ListItem.Episode,x,] | $INFO[Container($PARAM[list_id]).ListItem.Title]"/>
						<param name="vis" value="$EXP[hasWallWatchedIcon] + String.StartsWith(Container($PARAM[list_id]).PluginCategory,Season)"/>
						<param name="vis2" value="[$PARAM[focused] + Control.HasFocus($PARAM[list_id])] | [$PARAM[focused] + [Control.IsVisible(55) | Control.IsVisible(501)]]"/>
					</include>
					<!-- Episode badge: season view (no watched icon, shifted left) -->
					<include content="InfoBadge">
						<param name="left" value="31"/>
						<param name="top" value="1"/>
						<param name="max_width" value="530"/>
						<param name="label" value="$INFO[Container($PARAM[list_id]).ListItem.Season]$INFO[Container($PARAM[list_id]).ListItem.Episode,x,] | $INFO[Container($PARAM[list_id]).ListItem.Title]"/>
						<param name="vis" value="!$EXP[hasWallWatchedIcon] + String.StartsWith(Container($PARAM[list_id]).PluginCategory,Season)"/>
						<param name="vis2" value="[$PARAM[focused] + Control.HasFocus($PARAM[list_id])] | [$PARAM[focused] + [Control.IsVisible(55) | Control.IsVisible(501)]]"/>
					</include>
				</control>
				<control type="group">
					<visible>$EXP[isTVShow] | $EXP[isSeason]</visible>
					<top>289</top>
					<include content="InfoBadge">
						<param name="top" value="5.5"/>
						<param name="label" value="[UPPERCASE][LIGHT]$INFO[ListItem.Property(UnwatchedEpisodes),, remaining][/LIGHT][/UPPERCASE]"/>
						<param name="vis" value="[$PARAM[focused] + Control.HasFocus($PARAM[list_id])] | [$PARAM[focused] + [Control.IsVisible(55) | Control.IsVisible(501)]]"/>
						<param name="vis2" value="Integer.IsGreater(ListItem.Property(WatchedEpisodes),0) + !String.IsEqual(ListItem.Property(WatchedEpisodes),ListItem.Property(TotalEpisodes)) + !String.IsEqual(ListItem.Property(UnWatchedEpisodes),-1)"/>
					</include>
				</control>
				<include content="CollectionBadge">
					<param name="left" value="68"/>
					<param name="top" value="298"/>
					<param name="vis" value="$EXP[hasWallWatchedIcon]"/>
				</include>
				<include content="CollectionBadge">
					<param name="left" value="31"/>
					<param name="top" value="298"/>
					<param name="vis" value="!$EXP[hasWallWatchedIcon]"/>
				</include>
				<include content="ProgressBadge">
					<param name="left" value="31"/>
					<param name="top" value="298"/>
				</include>
				<control type="label">
					<left>30</left>
					<top>340</top>
					<width>562</width>
					<label>$INFO[Container($PARAM[list_id]).ListItem.Title]</label>
					<font>font12</font>
					<shadowcolor>text_shadow</shadowcolor>
					<textcolor>unfocused_text</textcolor>
					<align>center</align>
					<scroll>$PARAM[focused] + Control.HasFocus(501)</scroll>
					<scrollspeed>100</scrollspeed>
					<visible>!$EXP[isEpisode] + String.IsEqual(Container.ViewMode,$LOCALIZE[311023]) + Skin.HasSetting(Enable.501Titles)</visible>
				</control>
				<control type="image">
					<left>20</left>
					<top>11</top>
					<width>582</width>
					<height>327</height>
					<texture border="28" colordiffuse="$VAR[FocusColorTheme]" infill="false">masks/bordertexture-28.png</texture>
					<visible>[$PARAM[focused] + Control.HasFocus($PARAM[list_id])] | [$PARAM[focused] + [Control.IsVisible(55) | Control.IsVisible(501)]]</visible>
					<include condition="$PARAM[focused]">Animation_FocusTextureFade</include>
				</control>
			</control>
		</definition>
	</include>

	<!-- DEFAULT LAYOUT - No Titles -->
	<include name="View55_Default_NoTitles">
		<definition>
			<itemlayout width="471" height="283" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]">
				<control type="group">
					<include content="ViewUnfocusedAnimations">
						<param name="id" value="55"/>
					</include>
					<left>-2</left>
					<top>0</top>
					<include>LandscapeLayout</include>
				</control>
			</itemlayout>
			<focusedlayout width="471" height="283" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]" infoupdate="30">
				<control type="group">
					<depth>DepthContentPopout</depth>
					<left>-2</left>
					<top>0</top>
					<include content="LandscapeLayout">
						<param name="focused" value="true" />
					</include>
					<include>FocusBounce</include>
					<include>VideoTrailerControl</include>
				</control>
			</focusedlayout>
		</definition>
	</include>

	<!-- DEFAULT LAYOUT - Titles -->
	<include name="View55_Default_Titles">
		<definition>
			<itemlayout width="471" height="315" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]">
				<control type="group">
					<include content="ViewUnfocusedAnimations">
						<param name="id" value="55"/>
					</include>
					<left>-2</left>
					<top>0</top>
					<include>LandscapeLayout</include>
				</control>
			</itemlayout>
			<focusedlayout width="471" height="315" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]" infoupdate="30">
				<control type="group">
					<depth>DepthContentPopout</depth>
					<left>-2</left>
					<top>0</top>
					<include content="LandscapeLayout">
						<param name="focused" value="true" />
					</include>
					<include>FocusBounce</include>
					<include>VideoTrailerControl</include>
				</control>
			</focusedlayout>
		</definition>
	</include>

	<!-- SMALL LAYOUT - No Titles -->
	<include name="View55_Small_NoTitles">
		<definition>
			<itemlayout width="353" height="214" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]">
				<control type="group">
					<include content="ViewUnfocusedAnimations">
						<param name="id" value="55"/>
					</include>
					<left>2</left>
					<top>0</top>
					<include>SmallLandscapeLayout</include>
				</control>
			</itemlayout>
			<focusedlayout width="353" height="214" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]" infoupdate="30">
				<control type="group">
					<depth>DepthContentPopout</depth>
					<left>2</left>
					<top>0</top>
					<include content="SmallLandscapeLayout">
						<param name="focused" value="true" />
					</include>
					<include>FocusBounce</include>
					<include>VideoTrailerControl</include>
				</control>
			</focusedlayout>
		</definition>
	</include>

	<!-- SMALL LAYOUT - Titles -->
	<include name="View55_Small_Titles">
		<definition>
			<itemlayout width="353" height="240" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]">
				<control type="group">
					<include content="ViewUnfocusedAnimations">
						<param name="id" value="55"/>
					</include>
					<left>2</left>
					<top>0</top>
					<include>SmallLandscapeLayout</include>
				</control>
			</itemlayout>
			<focusedlayout width="353" height="240" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]" infoupdate="30">
				<control type="group">
					<depth>DepthContentPopout</depth>
					<left>2</left>
					<top>0</top>
					<include content="SmallLandscapeLayout">
						<param name="focused" value="true" />
					</include>
					<include>FocusBounce</include>
					<include>VideoTrailerControl</include>
				</control>
			</focusedlayout>
		</definition>
	</include>

	<include name="View_55_LandscapeInfo">
		<control type="group">
			<include>OpenClose_Right</include>
			<include>Visible_Right</include>
			<left>0</left>
			<top>70</top>
			<visible>Control.IsVisible(55)</visible>
			<control type="panel" id="55">
				<left>500</left>
				<right>0</right>
				<height>100%</height>
				<onleft>532</onleft>
				<onright>55</onright>
				<orientation>vertical</orientation>
				<viewtype label="311012">icon</viewtype>
				<preloaditems>2</preloaditems>
				<pagecontrol>532</pagecontrol>
				<scrolltime tween="cubic" easing="out">600</scrolltime>
				<onback condition="Player.HasMedia + !String.IsEmpty(Skin.String(TrailerPlaying))">Stop</onback>
				<onunfocus condition="Player.HasMedia + !String.IsEmpty(Skin.String(TrailerPlaying))">Stop</onunfocus>
				<onunfocus condition="!String.IsEmpty(Skin.String(TrailerPlaying))">Skin.Reset(TrailerPlaying)</onunfocus>
				<visible>[Container.Content(artists) + [String.IsEqual(Skin.String(Skin.ForcedView.artists),$LOCALIZE[311012]) | String.IsEmpty(Skin.String(Skin.ForcedView.artists))]] |

				[Container.Content(albums) + [String.IsEqual(Skin.String(Skin.ForcedView.albums),$LOCALIZE[311012]) | String.IsEmpty(Skin.String(Skin.ForcedView.albums))]] |

				[Container.Content(sets) + [String.IsEqual(Skin.String(Skin.ForcedView.sets),$LOCALIZE[311012]) | String.IsEmpty(Skin.String(Skin.ForcedView.sets))]] |

				[Container.Content(movies) + [String.IsEqual(Skin.String(Skin.ForcedView.movies),$LOCALIZE[311012]) | String.IsEmpty(Skin.String(Skin.ForcedView.movies))]] |

				[Container.Content(tvshows) + [String.IsEqual(Skin.String(Skin.ForcedView.tvshows),$LOCALIZE[311012]) | String.IsEmpty(Skin.String(Skin.ForcedView.tvshows))]] |

				[Container.Content(seasons) + [String.IsEqual(Skin.String(Skin.ForcedView.seasons),$LOCALIZE[311012]) | String.IsEmpty(Skin.String(Skin.ForcedView.seasons))]] |

				[Container.Content(episodes) + !String.StartsWith(Container.PluginCategory,Season) + [String.IsEqual(Skin.String(Skin.ForcedView.episodes.outside),$LOCALIZE[311012]) | String.IsEmpty(Skin.String(Skin.ForcedView.episodes.outside))]] |

				[Container.Content(episodes) + String.StartsWith(Container.PluginCategory,Season) + [String.IsEqual(Skin.String(Skin.ForcedView.episodes.inside),$LOCALIZE[311012]) | String.IsEmpty(Skin.String(Skin.ForcedView.episodes.inside))]] |

				[Container.Content(musicvideos) + [String.IsEqual(Skin.String(Skin.ForcedView.musicvideos),$LOCALIZE[311012]) | String.IsEmpty(Skin.String(Skin.ForcedView.musicvideos))]] |

				[Container.Content(images) + [String.IsEqual(Skin.String(Skin.ForcedView.images),$LOCALIZE[311012]) | String.IsEmpty(Skin.String(Skin.ForcedView.images))]] |

				[Container.Content(videos) + [String.IsEqual(Skin.String(Skin.ForcedView.videos),$LOCALIZE[311012]) | String.IsEmpty(Skin.String(Skin.ForcedView.videos))]] |

				[Container.Content(games) + [String.IsEqual(Skin.String(Skin.ForcedView.games),$LOCALIZE[311012]) | String.IsEmpty(Skin.String(Skin.ForcedView.games))]]</visible>

				<!-- DEFAULT LAYOUT - No Titles -->
				<include condition="String.IsEqual(Skin.String(ArtworkSize55Setting),0) + !Skin.HasSetting(Enable.55Titles)">View55_Default_NoTitles</include>
				<!-- DEFAULT LAYOUT - Titles -->
				<include condition="String.IsEqual(Skin.String(ArtworkSize55Setting),0) + Skin.HasSetting(Enable.55Titles)">View55_Default_Titles</include>
				<!-- SMALL LAYOUT - No Titles -->
				<include condition="String.IsEqual(Skin.String(ArtworkSize55Setting),1) + !Skin.HasSetting(Enable.55Titles)">View55_Small_NoTitles</include>
				<!-- SMALL LAYOUT - Titles -->
				<include condition="String.IsEqual(Skin.String(ArtworkSize55Setting),1) + Skin.HasSetting(Enable.55Titles)">View55_Small_Titles</include>

				<!-- EPISODES -->
				<itemlayout width="471" height="283" condition="Container.Content(episodes) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<include content="ViewUnfocusedAnimations">
							<param name="id" value="55"/>
						</include>
						<left>0</left>
						<top>0</top>
						<include>LandscapeLayout</include>
					</control>
				</itemlayout>
				<focusedlayout width="471" height="283" condition="Container.Content(episodes) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]" infoupdate="30">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>0</left>
						<top>0</top>
						<include content="LandscapeLayout">
							<param name="focused" value="true" />
						</include>
						<include>FocusBounce</include>
						<include>VideoTrailerControl</include>
					</control>
				</focusedlayout>
				<!-- <itemlayout width="623" height="373">
					<control type="group">
						<left>25</left>
						<top>0</top>
						<include>LandscapeLayout</include>
					</control>
				</itemlayout>
				<focusedlayout width="623" height="373" infoupdate="30">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<animation effect="zoom" start="100" end="105" time="200" tween="sine" easing="inout" center="auto">Focus</animation>
						<animation effect="zoom" start="105" end="100" time="200" tween="sine" easing="inout" center="auto">UnFocus</animation>
						<left>25</left>
						<top>0</top>
						<include content="LandscapeLayout">
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout> -->
			</control>
			<include content="TopBottomBars">
				<param name="top_visible" value="true"/>
				<param name="bottom_visible" value="true"/>
				<param name="top" value="-70"/>
				<param name="bottom" value="0"/>
			</include>
			<control type="label">
				<left>515</left>
				<right>video_header_right</right>
				<top>-45</top>
				<label>$VAR[LeftVideoHeader]</label>
				<font>font30_title_uppercase</font>
				<textcolor>$VAR[FocusColorTheme]</textcolor>
				<shadowcolor>text_shadow</shadowcolor>
				<align>left</align>
				<scroll>true</scroll>
				<scrollspeed>170</scrollspeed>
				<!-- <visible>!Window.IsVisible(busydialog)</visible> -->
				<animation effect="slide" end="2,0" condition="!Container.Content(episodes) + String.IsEqual(Skin.String(ArtworkSize55Setting),1)">Conditional</animation>
			</control>
			<control type="label">
				<right>27</right>
				<top>-45</top>
				<width>1815</width>
				<label>$VAR[RightVideoHeader]</label>
				<font>font30_title_uppercase</font>
				<textcolor>$VAR[FocusColorTheme]</textcolor>
				<shadowcolor>text_shadow</shadowcolor>
				<align>right</align>
				<!-- <visible>!Window.IsVisible(busydialog)</visible> -->
				<animation effect="slide" end="4,0" condition="!Container.Content(episodes) + String.IsEqual(Skin.String(ArtworkSize55Setting),1)">Conditional</animation>
			</control>
		</control>
	</include>

</includes>