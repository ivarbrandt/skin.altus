<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol>996</defaultcontrol>
	<include content="OpenClose_Slide_Left">
		<param name="distance" value="498" />
	</include>
	<onload condition="!String.IsEmpty(Window(Home).Property(CurrentDBType)) + !String.IsEqual(Window(Home).Property(CurrentDBType),season) + !String.IsEqual(Window(Home).Property(CurrentDBType),episode)">SetFocus(8001)</onload>
	<coordinates>
		<origin x="0" y="0"/>
	</coordinates>
	<controls>
		<control type="group">
			<width>498</width>
			<top>0</top>
			<bottom>0</bottom>
			<left>0</left>
			<animation effect="slide" start="100" end="-600,0" time="0" condition="String.IsEqual(Window(Home).Property(altus.pvr.hiding_ctx),true)">Conditional</animation>
			<include content="DialogBackgroundCommons">
				<param name="header_label" value="$VAR[ContextMenuTitleVar]" />
				<param name="header_id" value="1" />
				<param name="width" value="498" />
				<param name="top" value="40" />
				<param name="bottom" value="40" />
				<param name="left" value="-42" />
				<param name="border_texture" value="masks/bordertexture-46-thin_right.png" />
				<param name="diffuse_texture" value="masks/radius_46_right.png" />
				<param name="border_value" value="0,46,46,46" />
			</include>
			<control type="button">
				<left>-1920</left>
				<top>-1080</top>
				<width>5760</width>
				<height>3240</height>
				<texturefocus />
				<texturenofocus />
				<onclick>Action(close)</onclick>
			</control>
			<!-- <control type="image" id="999">
				<description>background image</description>
				<left>0</left>
				<top>0</top>
				<width>498</width>
				<height>780</height>
				<texture colordiffuse="$VAR[FocusColorTheme]">colors/commons.png</texture>
			</control> -->
			<control type="grouplist" id="996">
				<description>grouplist for context buttons</description>
				<left>40</left>
				<top>170</top>
				<height>825</height>
				<onright>Action(close)</onright>
				<usecontrolcoords>true</usecontrolcoords>
				<control type="button" id="8001">
					<height>75</height>
					<align>left</align>
					<width>418</width>
					<aligny>center</aligny>
					<textoffsetx>35</textoffsetx>
					<label>[I][B]Play Trailer (Altus)[/B][/I]</label>
					<font>font32</font>
					<textcolor>unfocused_text</textcolor>
					<focusedcolor>$VAR[FocusedTextColorVar]</focusedcolor>
					<texturefocus border="23" colordiffuse="$VAR[FocusColorTheme]">masks/radius_23.png</texturefocus>
					<texturenofocus />
					<onclick>RunScript(script.altus.helper, mode=play_trailer)</onclick>
					<visible>!String.IsEmpty(Window(Home).Property(CurrentDBType)) + !String.IsEqual(Window(Home).Property(CurrentDBType),season) + !String.IsEqual(Window(Home).Property(CurrentDBType),episode)</visible>
				</control>
			</control>
			<control type="button" id="1000">
				<description>button template</description>
				<left>0</left>
				<top></top>
				<width>418</width>
				<height>75</height>
				<align>left</align>
				<aligny>center</aligny>
				<textoffsetx>35</textoffsetx>
				<font>font32</font>
				<textcolor>unfocused_text</textcolor>
				<focusedcolor>$VAR[FocusedTextColorVar]</focusedcolor>
				<texturefocus border="23" colordiffuse="$VAR[FocusColorTheme]">masks/radius_23.png</texturefocus>
				<texturenofocus />
			</control>
		</control>
	</controls>
</window>