<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol>700</defaultcontrol>
  <onload condition="Control.IsVisible(703)">SetFocus(703)</onload>
  <onload condition="!Control.IsVisible(703)">SetFocus(704)</onload>
  <!-- <onload condition="VideoPlayer.Content(livetv)">SetFocus(704)</onload> -->
  <onunload>ClearProperty(LanguageNotification,home)</onunload>
  <onunload>SetProperty(osd_just_closed,1,home)</onunload>
  <onunload condition="Player.Playing">Skin.TimerStart(reset_osd_just_closed)</onunload>
  <animation effect="fade" start="0" end="100" time="300" condition="!Player.Paused">WindowOpen</animation>
  <animation effect="fade" start="100" end="0" time="300" condition="!Player.Paused">WindowClose</animation>
  <controls>
    <control type="label">
      <top>0</top>
      <height>100</height>
      <font>Font30</font>
      <textcolor>osd_light</textcolor>
      <label>$INFO[VideoPlayer.AudioStreamCount]</label>
    </control>
    <include content="OSDBackground"/>
    <include>PausedBadge</include>
    <control type="group">
      <bottom>0</bottom>
      <height>220</height>
      <control type="group">
        <top>-68</top>
        <animation effect="slide" start="0,60" end="0,0" time="400" tween="sine" easing="inout">WindowOpen</animation>
        <animation effect="slide" start="0,0" end="0,60" time="400" tween="sine" easing="inout">WindowClose</animation>
        <include content="Seekbar"/>
      </control>
      <control type="grouplist" id="700">
        <animation effect="slide" start="0,100" end="0,0" time="400" tween="sine" easing="inout">WindowOpen</animation>
        <animation effect="slide" start="0,0" end="0,100" time="400" tween="sine" easing="inout">WindowClose</animation>
        <bottom>21</bottom>
        <height>74</height>
        <left>120</left>
        <width>100%</width>
        <itemgap>27</itemgap>
        <orientation>horizontal</orientation>
        <align>left</align>
        <onleft>716</onleft>
        <onright>708</onright>
        <control type="radiobutton" id="701">
          <include content="OSDButton">
            <param name="texture" value="osd/fullscreen/buttons/previous.png"/>
          </include>
          <onclick>PlayerControl(Previous)</onclick>
          <visible>Player.HasSceneMarkers | Player.ChapterCount | Integer.IsGreater(Playlist.Length(video),1) | [Player.SeekEnabled + VideoPlayer.Content(livetv)]</visible>
        </control>
        <control type="radiobutton" id="702">
          <include content="OSDButton">
            <param name="texture" value="osd/fullscreen/buttons/rewind.png"/>
          </include>
          <onclick>PlayerControl(Rewind)</onclick>
          <visible>[Player.SeekEnabled + !VideoPlayer.Content(livetv)] + !Player.Paused</visible>
        </control>
        <control type="group" id="703">
          <width>70</width>
          <height>68</height>
          <visible>Player.PauseEnabled</visible>
          <control type="button" id="7031">
            <left>0</left>
            <top>0</top>
            <width>70</width>
            <height>68</height>
            <label></label>
            <font></font>
            <texturefocus colordiffuse="$VAR[PlayerProgressColor]">osd/fullscreen/buttons/button-fo.png</texturefocus>
            <texturenofocus />
            <onleft>702</onleft>
            <onright>704</onright>
            <onup>87</onup>
            <ondown>noop</ondown>
            <onclick>PlayerControl(Play)</onclick>
            <animation center="35,34" effect="zoom" end="100" reversible="false" start="90" time="480" tween="back">Focus</animation>
          </control>
          <control type="image">
            <left>13</left>
            <top>12</top>
            <width>44</width>
            <height>44</height>
            <visible>!Control.HasFocus(7031)</visible>
            <texture colordiffuse="ccf8f8f8">$VAR[PlayerControlsPlayImageVar]</texture>
          </control>
          <control type="image">
            <left>13</left>
            <top>12</top>
            <width>44</width>
            <height>44</height>
            <animation center="35,34" effect="zoom" end="100" reversible="false" start="90" time="480" tween="back" condition="Control.HasFocus(7031)">Conditional</animation>
            <visible>Control.HasFocus(7031)</visible>
            <texture colordiffuse="$VAR[PlayerProgressTextColor]">$VAR[PlayerControlsPlayImageVar]</texture>
          </control>
        </control>
        <control type="radiobutton" id="704">
          <include content="OSDButton">
            <param name="texture" value="osd/fullscreen/buttons/stop.png"/>
          </include>
          <onclick>PlayerControl(Stop)</onclick>
        </control>
        <control type="radiobutton" id="705">
          <include content="OSDButton">
            <param name="texture" value="osd/fullscreen/buttons/forward.png"/>
          </include>
          <onclick>PlayerControl(Forward)</onclick>
          <visible>[Player.SeekEnabled + !VideoPlayer.Content(livetv)] + !Player.Paused</visible>
        </control>
        <control type="radiobutton" id="706">
          <include content="OSDButton">
            <param name="texture" value="osd/fullscreen/buttons/next.png"/>
          </include>
          <onclick>PlayerControl(Next)</onclick>
          <visible>Player.HasSceneMarkers | Player.ChapterCount | Integer.IsGreater(Playlist.Length(video),1) | PVR.IsTimeShift</visible>
        </control>
      </control>
      <control type="grouplist" id="707">
        <animation effect="slide" start="0,100" end="0,0" time="400" tween="sine" easing="inout">WindowOpen</animation>
        <animation effect="slide" start="0,0" end="0,100" time="400" tween="sine" easing="inout">WindowClose</animation>
        <bottom>21</bottom>
        <height>74</height>
        <right>120</right>
        <width>100%</width>
        <itemgap>27</itemgap>
        <orientation>horizontal</orientation>
        <align>right</align>
        <usecontrolcoords>true</usecontrolcoords>
        <onleft>703</onleft>
        <onright>701</onright>
        <control type="grouplist">
          <orientation>vertical</orientation>
          <align>center</align>
          <itemgap>12</itemgap>
          <width>70</width>
          <visible>VideoPlayer.Content(movies) | VideoPlayer.Content(episodes)</visible>
          <control type="radiobutton" id="708">
            <include content="OSDButton">
              <param name="texture" value="osd/fullscreen/buttons/speak.png"/>
            </include>
            <!-- <onclick condition="String.IsEqual(Skin.String(OSDAudioButtonSetting),0)">SetProperty(LanguageNotification,true,home)</onclick>
            <onunfocus condition="String.IsEqual(Skin.String(OSDAudioButtonSetting),0)">ClearProperty(LanguageNotification,home)</onunfocus> -->
            <onclick condition="String.IsEqual(Skin.String(OSDAudioButtonSetting),0)">AudioNextLanguage</onclick>
            <onclick condition="String.IsEqual(Skin.String(OSDAudioButtonSetting),1)">ActivateWindow(osdaudiosettings)</onclick>
            <onleft condition="Control.IsVisible(703)">703</onleft>
            <onleft condition="!Control.IsVisible(703)">704</onleft>
            <onright>709</onright>
          </control>
          <control type="label">
            <top>0</top>
            <left>0</left>
            <height>70</height>
            <width>70</width>
            <font>Font12</font>
            <align>center</align>
            <label>[CAPITALIZE]$INFO[VideoPlayer.AudioLanguage][/CAPITALIZE]</label>
          </control>
        </control>
        <control type="grouplist">
          <orientation>vertical</orientation>
          <align>center</align>
          <itemgap>12</itemgap>
          <width>70</width>
          <visible>VideoPlayer.Content(movies) | VideoPlayer.Content(episodes)</visible>
          <control type="radiobutton" id="709">
            <include content="OSDButton">
              <param name="texture" value="osd/fullscreen/buttons/subtitles.png"/>
            </include>
            <!-- <onclick condition="String.IsEqual(Skin.String(OSDSubtitleButtonSetting),0)">SetProperty(LanguageNotification,true,home)</onclick>
            <onunfocus condition="String.IsEqual(Skin.String(OSDSubtitleButtonSetting),0)">ClearProperty(LanguageNotification,home)</onunfocus> -->
            <onclick condition="String.IsEqual(Skin.String(OSDSubtitleButtonSetting),0)">NextSubtitle</onclick>
            <onclick condition="String.IsEqual(Skin.String(OSDSubtitleButtonSetting),1)">ActivateWindow(osdsubtitlesettings)</onclick>
            <onleft>708</onleft>
            <onright>710</onright>
          </control>
          <control type="label">
            <top>0</top>
            <left>0</left>
            <height>70</height>
            <width>70</width>
            <font>Font12</font>
            <align>center</align>
            <label>[CAPITALIZE]$VAR[VideoPlayerSubtitleLanguage][/CAPITALIZE]</label>
          </control>
        </control>
        <control type="grouplist">
          <orientation>vertical</orientation>
          <align>center</align>
          <itemgap>12</itemgap>
          <width>70</width>
          <visible>!Player.Paused + [VideoPlayer.Content(movies) | VideoPlayer.Content(episodes)]</visible>
          <control type="radiobutton" id="710">
            <include content="OSDButton">
              <param name="texture" value="osd/fullscreen/buttons/subtitledelay.png"/>
            </include>
            <onclick>Dialog.Close(VideoOSD)</onclick>
            <onclick>SubTitleDelay</onclick>
            <onleft>709</onleft>
            <onright>711</onright>
          </control>
          <control type="label">
            <top>0</top>
            <left>0</left>
            <height>70</height>
            <width>70</width>
            <font>Font12</font>
            <align>center</align>
            <label></label>
          </control>
        </control>
        <control type="grouplist">
          <orientation>vertical</orientation>
          <align>center</align>
          <itemgap>12</itemgap>
          <width>70</width>
          <visible>!VideoPlayer.Content(livetv)</visible>
          <control type="radiobutton" id="711">
            <include content="OSDButton">
              <param name="texture" value="osd/fullscreen/buttons/bookmarks.png"/>
            </include>
            <onclick>ActivateWindow(videobookmarks)</onclick>
            <onleft>710</onleft>
            <onright>712</onright>
          </control>
          <control type="label">
            <top>0</top>
            <left>0</left>
            <height>70</height>
            <width>70</width>
            <font>Font12</font>
            <align>center</align>
            <label></label>
          </control>
        </control>
        <control type="grouplist">
          <orientation>vertical</orientation>
          <align>center</align>
          <itemgap>12</itemgap>
          <width>70</width>
          <visible>VideoPlayer.Content(livetv)</visible>
          <control type="radiobutton" id="712">
            <include content="OSDButton">
              <param name="texture" value="osd/fullscreen/buttons/pvrosdchannels.png"/>
            </include>
            <onclick>Dialog.Close(VideoOSD)</onclick>
            <onclick>ActivateWindow(PVROSDChannels)</onclick>
            <onleft>711</onleft>
            <onright>713</onright>
          </control>
          <control type="label">
            <top>0</top>
            <left>0</left>
            <height>70</height>
            <width>70</width>
            <font>Font12</font>
            <align>center</align>
            <label></label>
          </control>
        </control>
        <control type="grouplist">
          <orientation>vertical</orientation>
          <align>center</align>
          <itemgap>12</itemgap>
          <width>70</width>
          <visible>VideoPlayer.Content(livetv) + VideoPlayer.HasEPG</visible>
          <control type="group">
            <width>70</width>
            <height>70</height>
            <animation center="35,34" effect="zoom" end="100" reversible="false" start="90" time="480" tween="back">Focus</animation>
            <control type="button" id="713">
              <texturefocus colordiffuse="$VAR[PlayerProgressColor]">osd/fullscreen/buttons/button-fo.png</texturefocus>
              <texturenofocus/>
              <width>70</width>
              <height>70</height>
              <font></font>
              <animation center="35,34" effect="zoom" end="100" reversible="false" start="90" time="480" tween="back">Focus</animation>
              <onclick>Dialog.Close(VideoOSD)</onclick>
              <onclick>ActivateWindow(pvrchannelguide)</onclick>
              <onleft>712</onleft>
              <onright>714</onright>
            </control>
            <control type="image">
              <left>13</left>
              <top>13</top>
              <width>44</width>
              <height>44</height>
              <texture colordiffuse="$VAR[PVRGuideIconColor]">osd/fullscreen/buttons/calendar/$INFO[System.Date(d),,.png]</texture>
            </control>
          </control>
          <control type="label">
            <top>0</top>
            <left>0</left>
            <height>70</height>
            <width>70</width>
            <font>Font22</font>
            <align>center</align>
            <label></label>
          </control>
        </control>
        <control type="grouplist">
          <orientation>vertical</orientation>
          <align>center</align>
          <itemgap>12</itemgap>
          <width>70</width>
          <visible>VideoPlayer.Content(livetv) + VideoPlayer.HasEPG</visible>
          <control type="radiobutton" id="714">
            <include content="OSDButton">
              <param name="texture" value="osd/fullscreen/buttons/guide.png"/>
            </include>
            <onclick>Dialog.Close(VideoOSD)</onclick>
						<onclick>ActivateWindow(tvguide)</onclick>
            <onleft>713</onleft>
            <onright>715</onright>
          </control>
          <control type="label">
            <top>0</top>
            <left>0</left>
            <height>70</height>
            <width>70</width>
            <font>Font12</font>
            <align>center</align>
            <label></label>
          </control>
        </control>
        <control type="grouplist">
          <orientation>vertical</orientation>
          <align>center</align>
          <itemgap>12</itemgap>
          <width>70</width>
          <control type="radiobutton" id="715">
            <include content="OSDButton">
              <param name="texture" value="osd/fullscreen/buttons/info.png"/>
            </include>
            <!-- <onclick>$VAR[OSDStyleToggleVar]</onclick> -->
            <!-- <onclick condition="!Skin.HasSetting(Enable.DetailedOSD)">Notification(OSD, Detailed OSD enabled, 1000)</onclick> -->
            <onclick>playerprocessinfo</onclick>
            <onleft>714</onleft>
            <onright>716</onright>
          </control>
          <control type="label">
            <top>0</top>
            <left>0</left>
            <height>70</height>
            <width>70</width>
            <font>Font12</font>
            <align>center</align>
            <label></label>
          </control>
        </control>
        <control type="grouplist">
          <orientation>vertical</orientation>
          <align>center</align>
          <itemgap>12</itemgap>
          <width>70</width>
          <control type="radiobutton" id="716">
            <include content="OSDButton">
              <param name="texture" value="osd/fullscreen/buttons/settings.png"/>
            </include>
            <onclick>SetProperty(settingslist_content,osd,home)</onclick>
            <onclick>SetProperty(settingslist_header,$LOCALIZE[5],home)</onclick>
            <onclick>ActivateWindow(1101)</onclick>
            <onleft>715</onleft>
            <onright condition="Control.IsVisible(703)">703</onright>
            <onright condition="!Control.IsVisible(703)">704</onright>
          </control>
          <control type="label">
            <top>0</top>
            <left>0</left>
            <height>70</height>
            <width>70</width>
            <font>Font12</font>
            <align>center</align>
            <label></label>
          </control>
        </control>
      </control>
    </control>
  </controls>
</window>