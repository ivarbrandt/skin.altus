<?xml version="1.0" encoding="UTF-8"?>
<includes>

  <include name="WeatherWidgetLayout">
		<!-- <param name="item_limit">30</param> -->
		<param name="icon">$INFO[ListItem.Icon]</param>
		<param name="label2">$INFO[ListItem.Property(Outlook)]</param>
		<param name="focused">false</param>
		<definition>
			<control type="group">
        <top>34</top>
        <left>20</left>
				<!-- 279 -->
				<width>242</width>
				<height>242</height>
				<control type="image">
					<texture colordiffuse="66000000">masks/small-square.png</texture>
				</control>
				<control type="image">
					<texture colordiffuse="$VAR[FocusColorTheme]">masks/small-square.png</texture>
					<visible>$PARAM[focused] + Control.HasFocus($PARAM[list_id])</visible>
					<include condition="$PARAM[focused]">Animation_FocusTextureFade</include>
				</control>
				<control type="image">
          <centerleft>50%</centerleft>
          <top>10</top>
          <width>160</width>
          <height>160</height>
          <texture colordiffuse="unfocused_text" background="true">$PARAM[icon]</texture>
					<aspectratio>keep</aspectratio>
					<visible>![$PARAM[focused] + Control.HasFocus($PARAM[list_id])]</visible>
				</control>
				<control type="image">
          <centerleft>50%</centerleft>
          <top>10</top>
          <width>160</width>
          <height>160</height>
          <texture colordiffuse="$VAR[FocusedTextColorVar]" background="true">$PARAM[icon]</texture>
					<aspectratio>keep</aspectratio>
					<visible>$PARAM[focused] + Control.HasFocus($PARAM[list_id])</visible>
				</control>
				<control type="textbox">
					<centerleft>50%</centerleft>
					<top>150</top>
					<left>10</left>
					<right>10</right>
					<height>73</height>
					<align>center</align>
					<aligny>center</aligny>
					<font>font25</font>
					<label>$PARAM[label2]</label>
					<autoscroll delay="2000" time="3000" repeat="2000">$PARAM[focused]</autoscroll>
					<textcolor>$VAR[FocusedTextColorVar]</textcolor>
					<visible>$PARAM[focused] + Control.HasFocus($PARAM[list_id])</visible>
				</control>
				<control type="textbox">
					<centerleft>50%</centerleft>
					<top>150</top>
					<left>10</left>
					<right>10</right>
					<height>73</height>
					<align>center</align>
					<aligny>center</aligny>
					<font>font25</font>
					<label>$PARAM[label2]</label>
					<textcolor>unfocused_text</textcolor>
					<visible>![$PARAM[focused] + Control.HasFocus($PARAM[list_id])]</visible>
				</control>
				<control type="group">
					<centerleft>50%</centerleft>
					<height>75</height>
					<control type="label">
						<top>310</top>
						<align>center</align>
						<aligny>center</aligny>
						<font>font25</font>
						<label>$INFO[ListItem.Label] [COLOR accent_color][B]|[/B][/COLOR] $INFO[ListItem.Property(ShortDate)]</label>
						<visible>String.IsEqual(Skin.String(BackgroundSetting),0)</visible>
					</control>
					<control type="label">
						<top>310</top>
						<align>center</align>
						<aligny>center</aligny>
						<font>font25</font>
						<label>$INFO[ListItem.Label] [COLOR unfocused_text][B]|[/B][/COLOR] $INFO[ListItem.Property(ShortDate)]</label>
						<visible>String.IsEqual(Skin.String(BackgroundSetting),1) | String.IsEqual(Skin.String(BackgroundSetting),2)</visible>
					</control>
					<control type="label">
            <top>275</top>
						<align>center</align>
						<aligny>center</aligny>
						<font>font27</font>
						<label>$INFO[ListItem.Label2]</label>
					</control>
				</control>
			</control>
		</definition>
	</include>

</includes>