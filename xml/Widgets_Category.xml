<?xml version="1.0" encoding="UTF-8"?>
<includes>

  <include name="WidgetListCategory">
		<!-- <param name="item_limit">30</param> -->
		<!-- <param name="icon_height">230</param> -->
		<param name="icon">$INFO[ListItem.Icon]</param>
		<param name="visible">true</param>
		<definition>
			<include content="CategoryLabel">
				<param name="label">$PARAM[widget_header]</param>
				<param name="list_id" value="$PARAM[list_id]"/>
			</include>
			<include content="BusyListSpinner">
				<param name="list_id" value="$PARAM[list_id]"/>
			</include>
			<control type="fixedlist" id="$PARAM[list_id]">
				<top>107</top>
				<right>0</right>
				<left>45</left>
				<height>370</height>
				<focusposition>0</focusposition>
				<movement>3</movement>
				<onright>$PARAM[list_id]</onright>
				<movement>5</movement>
				<onfocus>ClearProperty(FlixWidget,Home)</onfocus>
				<onfocus>ClearProperty(FeatureWidgetFocused,Home)</onfocus>
				<onfocus>ClearProperty(altus_stacked_linked_list_id,home)</onfocus>
				<include content="WidgetListCommon">
					<param name="list_id" value="$PARAM[list_id]"/>
				</include>
				<!-- <include content="WidgetZoomAnimation">
					<param name="list_id" value="$PARAM[list_id]" />
					<param name="c2" value="282" />
				</include> -->
				<visible>Integer.IsGreater(Container($PARAM[list_id]).NumItems,0) | Container($PARAM[list_id]).IsUpdating</visible>
				<itemlayout width="339">
					<control type="group">
						<left>-20</left>
						<top>55</top>
						<include content="WidgetListCategoryLayout">
							<param name="list_id" value="$PARAM[list_id]" />
							<param name="icon" value="$PARAM[icon]" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout width="339" infoupdate="30">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>-20</left>
						<top>55</top>
						<include content="WidgetListCategoryLayout">
							<param name="list_id" value="$PARAM[list_id]" />
							<param name="icon" value="$PARAM[icon]" />
							<param name="focused" value="true" />
						</include>
						<include>VideoTrailerControl</include>
					</control>
				</focusedlayout>
				<content target="$PARAM[widget_target]" sortby="$PARAM[list_id]" limit="$PARAM[item_limit]">$PARAM[content_path]</content>
			</control>
			<include content="WidgetLeftRightArrows">
				<param name="list_id" value="$PARAM[list_id]" />
				<param name="posy" value="238" />
			</include>
		</definition>
	</include>

	<include name="WidgetListCategoryStacked">
		<!-- <param name="item_limit">30</param> -->
		<!-- <param name="icon_height">230</param> -->
		<param name="icon">$PARAM[icon]</param>
		<param name="visible">true</param>
		<definition>
			<include content="CategoryLabelWidget">
				<param name="label">$PARAM[widget_header]</param>
				<param name="list_id" value="$PARAM[list_id]"/>
			</include>
			<include content="BusyListWidgetSpinner">
				<param name="list_id" value="$PARAM[list_id]"/>
				<param name="posy" value="187"/>
			</include>
			<control type="fixedlist" id="$PARAM[list_id]">
				<top>107</top>
				<right>0</right>
				<left>45</left>
				<!-- 350 -->
				<height>273</height>
				<focusposition>0</focusposition>
				<movement>4</movement>
				<onright>$PARAM[list_id]</onright>
				<onfocus>RunScript(script.altus.helper,mode=widget_monitor&amp;list_id=$PARAM[list_id])</onfocus>
				<onfocus>SetProperty(altus_saved_list_id,$PARAM[list_id],home)</onfocus>
				<onfocus>SetProperty(altus_child_id,$PARAM[child_id],home)</onfocus>
				<onfocus>ClearProperty(FlixWidget,Home)</onfocus>
				<onfocus>ClearProperty(FeatureWidgetFocused,Home)</onfocus>
				<onfocus>ClearProperty(altus_flix_linked_list_id,home)</onfocus>
				<onfocus>ClearProperty(altus_stacked_linked_list_id,home)</onfocus>
				<include content="WidgetListCommonStacked">
					<param name="list_id" value="$PARAM[list_id]"/>
				</include>
				<!-- <animation effect="slide" end="7,0" time="300" condition="Control.HasFocus($PARAM[list_id])">Conditional</animation> -->
				<animation condition="!String.IsEmpty(Window(Home).Property(FlixWidget)) + Integer.IsEqual($PARAM[list_id],Window(Home).Property(altus_flix_linked_list_id))" reversible="false">
					<effect type="fade" start="100" end="0" time="400" />
				</animation>
				<!-- <visible>Integer.IsGreater(Container($PARAM[list_id]).NumItems,0) | Container($PARAM[list_id]).IsUpdating</visible> -->
				<itemlayout width="271" height="393" infoupdate="30">
					<control type="group">
						<left>-20</left>
						<top>55</top>
						<include content="WidgetListCategoryStackedLayout">
							<param name="list_id" value="$PARAM[list_id]" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout width="271" height="393" infoupdate="30">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>-20</left>
						<top>55</top>
						<include content="WidgetListCategoryStackedLayout">
							<param name="list_id" value="$PARAM[list_id]" />
							<param name="focused" value="true" />
						</include>
						<include>VideoTrailerControl</include>
					</control>
				</focusedlayout>
				<content target="$PARAM[widget_target]" sortby="$PARAM[list_id]" limit="$PARAM[item_limit]">$PARAM[content_path]</content>
			</control>
			<include content="WidgetLeftRightArrows">
				<param name="list_id" value="$PARAM[list_id]" />
				<param name="posy" value="312" />
			</include>
		</definition>
	</include>

</includes>
