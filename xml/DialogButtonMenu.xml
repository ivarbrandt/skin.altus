<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol>9000</defaultcontrol>
	<coordinates>
		<origin x="0" y="0"/>
	</coordinates>
	<include content="OpenClose_Slide_Left">
		<param name="distance" value="498" />
	</include>
	<controls>
		<control type="group">
			<include content="DialogBackgroundCommons">
				<param name="header_label" value="$LOCALIZE[31072]" />
				<param name="header_id" value="1" />
				<param name="width" value="498" />
				<param name="top" value="40" />
				<param name="left" value="-42" />
				<param name="bottom" value="40" /> 
				<param name="border_texture" value="masks/bordertexture-46-thin_right.png" />
				<param name="diffuse_texture" value="masks/radius_46_right.png" />
				<param name="border_value" value="0,46,46,46" />
			</include>
			<left>0</left>
			<width>578</width>
			<control type="panel" id="9000">
				<include>ButtonMenuList</include>
				<content>
					<item>
						<label>Reload skin</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>ReloadSkin()</onclick>
						<property name="icon">icons/dialog/reload.png</property>
					</item>
					<item>
						<label>Skin settings</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>ActivateWindow(SkinSettings.xml)</onclick>
						<property name="icon">icons/dialog/settings.png</property>
					</item>
					<item>
						<label>Toggle debugging</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>Skin.ToggleDebug()</onclick>
						<property name="icon">icons/dialog/bug.png</property>
					</item>
					<item>
						<label>System information</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>ActivateWindow(systeminfo)</onclick>
						<property name="icon">icons/dialog/info.png</property>
					</item>
					<item>
						<label>$LOCALIZE[13016]</label>
						<onclick>Powerdown()</onclick>
						<visible>System.CanPowerDown</visible>
						<property name="icon">icons/dialog/shutdown.png</property>
					</item>
					<item>
						<label>$LOCALIZE[20150]</label>
						<onclick>AlarmClock(shutdowntimer,Shutdown())</onclick>
						<visible>!System.HasAlarm(shutdowntimer)</visible>
						<visible>System.CanPowerDown | System.CanSuspend | System.CanHibernate</visible>
						<property name="icon">icons/dialog/timer.png</property>
					</item>
					<item>
						<label>$LOCALIZE[20151] $INFO[System.AlarmPos,(,)]</label>
						<onclick>CancelAlarm(shutdowntimer)</onclick>
						<visible>System.HasAlarm(shutdowntimer)</visible>
						<property name="icon">icons/dialog/cancel-timer.png</property>
					</item>
					<item>
						<label>$LOCALIZE[13011]</label>
						<onclick>Suspend()</onclick>
						<visible>System.CanSuspend</visible>
						<property name="icon">icons/dialog/suspend.png</property>
					</item>
					<item>
						<label>$LOCALIZE[13010]</label>
						<onclick>Hibernate()</onclick>
						<visible>System.CanHibernate</visible>
						<property name="icon">icons/dialog/hibernate.png</property>
					</item>
					<item>
						<label>$LOCALIZE[13013]</label>
						<onclick>Reset()</onclick>
						<visible>System.CanReboot</visible>
						<property name="icon">icons/dialog/restart.png</property>
					</item>
					<item>
						<label>$LOCALIZE[20126] $INFO[system.profilename]</label>
						<onclick>dialog.close(all,true)</onclick>
						<onclick>System.LogOff</onclick>
						<visible>System.HasLoginScreen | Integer.IsGreater(System.ProfileCount,1)</visible>
						<visible>System.Loggedon</visible>
						<property name="icon">icons/dialog/logout.png</property>
					</item>
					<item>
						<label>$VAR[MasterModeLabel]</label>
						<onclick>mastermode</onclick>
						<visible>System.HasLocks</visible>
						<property name="icon">icons/dialog/lock.png</property>
					</item>
					<item>
						<label>$LOCALIZE[13017]</label>
						<onclick>InhibitIdleShutdown(true)</onclick>
						<visible>System.HasShutdown +!System.IdleShutdownInhibited</visible>
						<property name="icon">icons/dialog/eye.png</property>
					</item>
					<item>
						<label>$LOCALIZE[13018]</label>
						<onclick>InhibitIdleShutdown(false)</onclick>
						<visible>System.HasShutdown + System.IdleShutdownInhibited</visible>
						<property name="icon">icons/dialog/eye-off.png</property>
					</item>
					<item>
						<label>$LOCALIZE[13012]</label>
						<onclick>Quit()</onclick>
						<visible>System.ShowExitButton</visible>
						<property name="icon">icons/dialog/quit.png</property>
					</item>
				</content>
			</control>
		</control>
	</controls>
</window>
