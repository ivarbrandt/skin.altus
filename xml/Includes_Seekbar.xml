<?xml version="1.0" encoding="UTF-8"?>
<includes>

  <include name="Seekbar">
		<control type="group">
			<top>-6</top>
			<control type="group">
				<left>120</left>
				<right>120</right>
				<top>100</top>
				<height>20</height>
				<control type="group">
					<visible>!VideoPlayer.HasEPG</visible>
					<control type="progress">
						<texturebg border="10" colordiffuse="$VAR[PlayerProgressColor]">special://skin/resources/progressbackosd.png</texturebg>
						<midtexture border="10" colordiffuse="$VAR[PlayerCacheColor]">special://skin/resources/progressosd.png</midtexture>
						<info>Player.ProgressCache</info>
					</control>
					<control type="progress">
						<texturebg border="10" colordiffuse="00FFFFFF">special://skin/resources/progressosd.png</texturebg>
						<midtexture border="10" colordiffuse="$VAR[PlayerProgressColor]">special://skin/resources/progressosd.png</midtexture>
						<info>Player.Progress</info>
					</control>
				</control>
				<control type="group">
					<visible>VideoPlayer.HasEPG</visible>
					<control type="progress">
						<texturebg border="10" colordiffuse="$VAR[PlayerProgressColor]">special://skin/resources/progressbackosd.png</texturebg>
						<midtexture border="10" colordiffuse="$VAR[PlayerProgressColor]">special://skin/resources/progressosd.png</midtexture>
						<info>PVR.TimeshiftProgressPlayPos</info>
						<info2>PVR.TimeshiftProgressEpgStart</info2>
					</control>
					<!-- <control type="progress">
						<texturebg colordiffuse="00FFFFFF">osd/ProgressBack.png</texturebg>
						<midtexture colordiffuse="player_cache">osd/Progress.png</midtexture>
						<info>PVR.TimeshiftProgressEpgEnd</info>
						<info2>PVR.TimeshiftProgressPlayPos</info2>
					</control> -->
				</control>
			</control>
			<control type="ranges">
				<left>120</left>
				<top>110.3</top>
				<width>1680</width>
				<height>10</height>
				<texturebg border="2" colordiffuse="00FFFFFF">special://skin/resources/ProgressBack.png</texturebg>
				<righttexture colordiffuse="osd_light" border="1">special://skin/resources/Progress.png</righttexture>
				<info>Player.Chapters</info>
			</control>
			<control type="slider" id="401">
				<left>120</left>
				<top>100</top>
				<width>1680</width>
				<height>10</height>
				<orientation>horizontal</orientation>
				<texturesliderbar colordiffuse="00FFFFFF">special://skin/resources/ProgressBack.png</texturesliderbar>
				<textureslidernib colordiffuse="unfocused_text">special://skin/resources/Progress.png</textureslidernib>
				<textureslidernibfocus colordiffuse="unfocused_text">special://skin/resources/Progress.png</textureslidernibfocus>
				<visible>Player.SeekEnabled + Player.Seeking</visible>
			</control>
			<control type="label">
				<visible>!Window.IsActive(VideoOSD.xml)</visible>
				<top>33</top>
				<height>40</height>
				<font>font32</font>
				<textcolor>osd_light</textcolor>
				<align>center</align>
				<label>$VAR[SeekLabel]</label>
			</control>
			<control type="label">
				<visible>Player.IsTempo</visible>
				<top>39</top>
				<height>40</height>
				<font>font32</font>
				<textcolor>osd_light</textcolor>
				<align>center</align>
				<label>$LOCALIZE[31142]: $INFO[Player.PlaySpeed]</label>
			</control>
			<control type="label">
				<top>0</top>
				<left>123</left>
				<width>1680</width>
				<height>40</height>
				<font>font60</font>
				<textcolor>osd_light</textcolor>
				<label>$VAR[MainNowPlayingLabelVar]</label>
				<visible>String.IsEmpty(Player.Art(clearlogo)) | [Skin.HasSetting(Disable.OSDClearlogo) + !Skin.HasSetting(Disable.OSDTitle)]</visible>
				<animation effect="fade" time="500">VisibleChange</animation>
			</control>
			<control type="image">
				<top>-42</top>
				<left>120</left>
				<width>570</width>
				<height>120</height>
				<texture background="true">$INFO[Window(Home).Property(listitem_clearlogo_cropped_video)]</texture>
				<aspectratio align="left" aligny="bottom">keep</aspectratio>
				<animation effect="fade" time="400">VisibleChange</animation>
				<visible>!VideoPlayer.Content(livetv) + !Skin.HasSetting(Disable.OSDClearlogo) + !String.IsEmpty(Window(Home).Property(listitem_clearlogo_cropped_video))</visible>
			</control>
			<control type="image">
				<left>120</left>
				<top>-41</top>
				<width>363</width>
				<height>120</height>
				<texture>$INFO[Window(Home).Property(listitem_clearlogo_cropped_video)]</texture>
				<aspectratio align="left" aligny="bottom">keep</aspectratio>
				<visible>VideoPlayer.Content(livetv) + !Skin.HasSetting(Disable.OSDClearlogo) + !String.IsEmpty(Window(Home).Property(listitem_clearlogo_cropped_video))</visible>
			</control>
			<control type="grouplist">
				<top>134</top>
				<left>115</left>
				<height>54</height>
				<width>1375</width>
				<orientation>horizontal</orientation>
				<itemgap>12</itemgap>
				<!-- <aligny>center</aligny>
				<align>left</align> -->
				<include content="OSD_FlixInfoIcon">
					<param name="flixlabel" value="$VAR[Resolution_Label]"/>
					<param name="visible" value="!String.IsEmpty(VideoPlayer.VideoResolution) + !Skin.HasSetting(Disable.OSDVideoCodec)"/>
				</include>
				<include content="OSD_FlixInfoIcon">
					<param name="flixlabel" value="$VAR[AudioCodec_Label]"/>
					<param name="visible" value="!String.IsEmpty(VideoPlayer.AudioCodec) + !Skin.HasSetting(Disable.OSDAudioCodec)"/>
				</include>
				<include content="OSD_FlixInfoIcon">
					<param name="flixlabel" value="$VAR[AudioChannels_Label]"/>
					<param name="visible" value="!String.IsEmpty(VideoPlayer.AudioChannels) + !Skin.HasSetting(Disable.OSDAudioChannels)"/>
				</include>
				<control type="label">
					<width max="1050">auto</width>
					<font>font32</font>
					<aligny>left</aligny>
					<textoffsety>-7</textoffsety>
					<textcolor>osd_light</textcolor>
					<label>$VAR[MiniNowPlayingLabelVar]</label>
					<animation effect="fade" time="500">VisibleChange</animation>
					<visible>!Skin.HasSetting(Disable.OSDClearlogo) | !Skin.HasSetting(Disable.OSDTitle)</visible>
					<scroll>true</scroll>
					<scrollspeed>150</scrollspeed>
				</control>
			</control>
			<control type="label">
				<visible>String.IsEmpty(Window(home).Property(LanguageNotification)) + !Control.IsVisible(33000)</visible>
				<top>33</top>
				<right>120</right>
				<width>390</width>
				<height>40</height>
				<font>font32</font>
				<textcolor>osd_light</textcolor>
				<align>right</align>
				<label>$VAR[PlayerEndTimeVar]</label>
			</control>
			<control type="label">
				<top>127</top>
				<right>120</right>
				<width>300</width>
				<height>40</height>
				<font>font32</font>
				<textcolor>$VAR[FocusColorTheme]</textcolor>
				<align>right</align>
				<label>$VAR[PlayerElapsedTimeVar] [B]|[/B] $VAR[PlayerTimeRemainingVar]</label>
			</control>
		</control>
	</include>

	<include name="PausedBadge">
		<control type="group">
      <visible>Player.Paused</visible>
      <animation effect="fade" time="400">VisibleChange</animation>
      <animation effect="zoom" center="auto" end="200,200" time="400" condition="Player.Playing" reversible="false">Conditional</animation>
      <control type="image">
        <centertop>50%</centertop>
        <centerleft>50%</centerleft>
				<include>GlowPulse</include>
        <width>150</width>
        <height>150</height>
        <texture colordiffuse="$VAR[FocusColorTheme]">osd/pausebackground.png</texture>
        <aspectratio>keep</aspectratio>
      </control>
      <control type="image">
        <centertop>50%</centertop>
        <centerleft>50%</centerleft>
        <width>100</width>
        <height>100</height>
        <texture colordiffuse="$VAR[PlayerCacheColor]">$VAR[OSDPausedTexture]</texture>
        <aspectratio>keep</aspectratio>
      </control>
    </control>
	</include>

	<include name="OSD_FlixInfoIcon">
		<control type="togglebutton">
			<width>auto</width>
			<height>42</height>
			<align>left</align>
			<textoffsetx>13</textoffsetx>
			<textoffsety>4.3</textoffsety>
			<font>PlayerCodecs</font>
			<textcolor>CC080808</textcolor>
			<texturenofocus border="13" colordiffuse="osd_light">masks/flixicon-filled.png</texturenofocus>
			<label>[UPPERCASE][LIGHT]$PARAM[flixlabel][/LIGHT][/UPPERCASE]</label>
			<visible>$PARAM[visible]</visible>
		</control>
	</include>

	<include name="OSDBackground">
		<control type="image">
			<bottom>0</bottom>
			<height>700</height>
			<texture colordiffuse="e0080808">osd/osdoverlay.png</texture>
		</control>
	</include>

</includes>