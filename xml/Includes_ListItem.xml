  <include name="ListItemTwoLine">
  <param name="focused" default="false" />
    <definition>
      <control type="group">
        <control type="image">
          <visible>Control.HasFocus($PARAM[id]) + $PARAM[focused]</visible>
          <top>15</top>
          <bottom>10</bottom>
          <width>5</width>
          <texture colordiffuse="$VAR[FocusColorTheme]">colors/white.png</texture>
        </control>
        <control type="group">
          <control type="label">
            <visible>!Control.HasFocus($PARAM[id]) | !$PARAM[focused]</visible>
            <top>12</top>
            <height>34</height>
            <left>20</left>
            <right>0</right>
            <aligny>top</aligny>
            <font>font32</font>
            <textcolor>unfocused_text</textcolor>
            <label>$PARAM[MainLabel]</label>
          </control>
          <control type="label">
            <visible>Control.HasFocus($PARAM[id]) + $PARAM[focused]</visible>
            <top>12</top>
            <height>34</height>
            <left>20</left>
            <right>0</right>
            <aligny>top</aligny>
            <font>font37</font>
            <textcolor>white</textcolor>
            <label>[B]$PARAM[MainLabel][/B]</label>
            <scroll>true</scroll>
            <scrollspeed>75</scrollspeed>
          </control>
        </control>
        <control type="label">
          <animation effect="slide" start="0,0" end="32,0" time="0" condition="[$EXP[isMovie] | $EXP[isTVShow] | $EXP[isSeason] | $EXP[isEpisode]]">Conditional</animation>
          <bottom>24</bottom>
          <height>25</height>
          <left>20</left>
          <right>0</right>
          <aligny>top</aligny>
          <font>font27</font>
          <textcolor>unfocused_text</textcolor>
          <label>$PARAM[SubLabel]</label>
          <visible>!Control.HasFocus($PARAM[id]) | !$PARAM[focused]</visible>
        </control>
        <control type="label">
          <animation effect="slide" start="0,0" end="32,0" time="0" condition="[$EXP[isMovie] | $EXP[isTVShow] | $EXP[isSeason] | $EXP[isEpisode]]">Conditional</animation>
          <bottom>24</bottom>
          <height>25</height>
          <left>20</left>
          <right>0</right>
          <aligny>top</aligny>
          <font>font27</font>
          <textcolor>unfocused_text</textcolor>
          <label>$PARAM[SubLabel]</label>
          <visible>Control.HasFocus($PARAM[id]) + $PARAM[focused]</visible>
          <scroll>true</scroll>
          <scrollspeed>75</scrollspeed>
        </control>
      </control>
    </definition>
  </include>

  <include name="SubmenuListCommon">
		<left>0</left>
		<top>0</top>
		<width>378</width>
		<bottom>0</bottom>
		<orientation>vertical</orientation>
		<scrolltime tween="cubic" easing="out">300</scrolltime>
