  <include name="MainMenuListItem">
    <param name="focused">false</param>
    <param name="img_top">0</param>
    <param name="img_bottom">0</param>
    <param name="align">left</param>
    <param name="left_right_text">30</param>
    <!-- <param name="img_left">47</param> -->
    <param name="focused_font">font37_title</param>
    <param name="unfocused_font">font37</param>
    <param name="img_texture">masks/radius_23.png</param>
    <param name="focused_text">$VAR[FocusedTextColorVar]</param>
    <definition>
      <control type="group">
        <control type="image">
          <top>$PARAM[img_top]</top>
          <bottom>$PARAM[img_bottom]</bottom>
          <left>0</left>
          <right>0</right>
          <texture border="23" colordiffuse="$VAR[FocusColorTheme]">$PARAM[img_texture]</texture>
          <visible>Control.HasFocus($PARAM[id]) + $PARAM[focused]</visible>
          <include condition="$PARAM[focused]">Animation_FocusTextureFade</include>
          <!-- <animation effect="fade" start="100" end="50" time="40" condition="Window.IsVisible(tvchannels) + !Control.HasFocus(49)">Conditional</animation> -->
        </control>
        <!-- Section icon -->
        <control type="image">
          <left>25</left>
          <top>19</top>
          <width>47</width>
          <height>47</height>
          <texture diffuse="masks/mainmenu-img.png" colordiffuse="unfocused_text">$VAR[HomeMenuIcon]</texture>
          <aspectratio>keep</aspectratio>
          <visible>[!String.IsEmpty(ListItem.Property(icon)) | String.IsEqual(ListItem.Property(id),weather)] + [!Control.HasFocus($PARAM[id]) | !$PARAM[focused]] + ![String.IsEqual(ListItem.Property(id),weather) + !Weather.IsFetched]</visible>
        </control>
        <control type="image">
          <left>25</left>
          <top>19</top>
          <width>47</width>
          <height>47</height>
          <texture diffuse="masks/mainmenu-img.png" colordiffuse="$VAR[FocusedTextColorVar]">$VAR[HomeMenuIcon]</texture>
          <aspectratio>keep</aspectratio>
          <visible>[!String.IsEmpty(ListItem.Property(icon)) | String.IsEqual(ListItem.Property(id),weather)] + Control.HasFocus($PARAM[id]) + $PARAM[focused] + ![String.IsEqual(ListItem.Property(id),weather) + !Weather.IsFetched]</visible>
        </control>
        <!-- Weather placeholder icon (before weather fetched) -->
        <control type="image">
          <left>25</left>
          <top>19</top>
          <width>47</width>
          <height>47</height>
          <texture diffuse="masks/mainmenu-img.png" colordiffuse="unfocused_text">icons/weather/cloudy.png</texture>
          <aspectratio>keep</aspectratio>
          <visible>String.IsEqual(ListItem.Property(id),weather) + !Weather.IsFetched + [!Control.HasFocus($PARAM[id]) | !$PARAM[focused]]</visible>
        </control>
        <control type="image">
          <left>25</left>
          <top>19</top>
          <width>47</width>
          <height>47</height>
          <texture diffuse="masks/mainmenu-img.png" colordiffuse="$VAR[FocusedTextColorVar]">icons/weather/cloudy.png</texture>
          <aspectratio>keep</aspectratio>
          <visible>String.IsEqual(ListItem.Property(id),weather) + !Weather.IsFetched + Control.HasFocus($PARAM[id]) + $PARAM[focused]</visible>
        </control>
        <control type="group">
          <visible>String.IsEmpty(ListItem.Property(icon)) + !String.IsEqual(ListItem.Property(id),weather)</visible>
          <control type="label">
            <left>$PARAM[left_right_text]</left>
            <right>$PARAM[left_right_text]</right>
            <aligny>center</aligny>
            <font>$PARAM[unfocused_font]</font>
            <textcolor>unfocused_text</textcolor>
            <label>$VAR[MenuCaseVar]</label>
            <align>$PARAM[align]</align>
            <shadowcolor>text_shadow</shadowcolor>
            <visible>!Control.HasFocus($PARAM[id]) | !$PARAM[focused]</visible>
          </control>
          <control type="label">
            <left>$PARAM[left_right_text]</left>
            <right>$PARAM[left_right_text]</right>
            <aligny>center</aligny>
            <font>$PARAM[focused_font]</font>
            <label>$VAR[MenuCaseVar]</label>
            <textcolor>$PARAM[focused_text]</textcolor>
            <align>$PARAM[align]</align>
            <!-- <textcolor>FFFFFFFF</textcolor> -->
            <shadowcolor>text_shadow</shadowcolor>
            <visible>Control.HasFocus($PARAM[id]) + $PARAM[focused]</visible>
            <scrollspeed>150</scrollspeed>
            <scroll>$PARAM[focused]</scroll>
          </control>
          <control type="label">
            <left>$PARAM[left_right_text]</left>
            <right>$PARAM[left_right_text]</right>
            <aligny>center</aligny>
            <font>$PARAM[unfocused_font]</font>
            <align>$PARAM[align]</align>
            <textcolor>unfocused_text</textcolor>
            <label>$VAR[MenuCaseVar]</label>
            <shadowcolor>text_shadow</shadowcolor>
            <visible>!Control.HasFocus($PARAM[id]) | !$PARAM[focused]</visible>
          </control>
        </control>
        <control type="group">
          <visible>!String.IsEmpty(ListItem.Property(icon)) | String.IsEqual(ListItem.Property(id),weather)</visible>
          <control type="label">
            <left>87</left>
            <right>27</right>
            <aligny>center</aligny>
            <font>$PARAM[unfocused_font]</font>
            <textcolor>unfocused_text</textcolor>
            <label>$VAR[MenuCaseVar]</label>
            <align>$PARAM[align]</align>
            <shadowcolor>text_shadow</shadowcolor>
            <visible>!Control.HasFocus($PARAM[id]) | !$PARAM[focused]</visible>
          </control>
          <control type="label">
            <left>87</left>
            <right>27</right>
            <aligny>center</aligny>
            <font>$PARAM[focused_font]</font>
            <label>$VAR[MenuCaseVar]</label>
            <textcolor>$PARAM[focused_text]</textcolor>
            <align>$PARAM[align]</align>
            <shadowcolor>text_shadow</shadowcolor>
            <visible>Control.HasFocus($PARAM[id]) + $PARAM[focused]</visible>
            <scrollspeed>150</scrollspeed>
            <scroll>$PARAM[focused]</scroll>
          </control>
          <control type="label">
            <left>87</left>
            <right>27</right>
            <aligny>center</aligny>
            <font>$PARAM[unfocused_font]</font>
            <align>$PARAM[align]</align>
            <textcolor>unfocused_text</textcolor>
            <label>$VAR[MenuCaseVar]</label>
            <shadowcolor>text_shadow</shadowcolor>
            <visible>!Control.HasFocus($PARAM[id]) | !$PARAM[focused]</visible>
          </control>
        </control>
      </control>
    </definition>
  </include>

