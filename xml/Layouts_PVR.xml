						<centerleft>50%</centerleft>
						<top>320</top>
						<width>240</width>
						<height>75</height>
						<align>center</align>
						<aligny>center</aligny>
						<label>$PARAM[label4]</label>
						<font>font25</font>
						<textcolor>unfocused_text</textcolor>
						<selectedcolor>unfocused_text</selectedcolor>
					</control> -->
				</control>
        <control type="group">
          <visible>!Integer.IsEqual(ListItem.Progress,0) + ![$PARAM[focused] + Control.HasFocus($PARAM[list_id])]</visible>
          <control type="progress">
            <centerleft>50%</centerleft>
            <top>223</top>
            <width>140</width>
            <height>6</height>
            <info>ListItem.PercentPlayed</info>
          </control>
          <control type="progress">
            <centerleft>50%</centerleft>
            <top>223</top>
            <width>140</width>
            <height>6</height>
            <info>ListItem.Progress</info>
          </control>
        </control>
        <control type="group">
          <visible>!Integer.IsEqual(ListItem.Progress,0) + [$PARAM[focused] + Control.HasFocus($PARAM[list_id])]</visible>
          <control type="progress">
						<centerleft>50%</centerleft>
						<midtexture colordiffuse="$VAR[FocusedTextColorVar]">colors/white.png</midtexture>
						<texturebg colordiffuse="$VAR[FocusedTextColorVar]">colors/white_50.png</texturebg>
