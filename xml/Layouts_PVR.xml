<?xml version="1.0" encoding="UTF-8"?>
<includes>

  <include name="WidgetListPVRLayout">
		<!-- <param name="item_limit">30</param> -->
		<param name="icon">$INFO[ListItem.Icon]</param>
    <param name="label">$INFO[ListItem.ChannelName]</param>
		<param name="label2">$INFO[ListItem.Title]</param>
		<param name="label3">$INFO[ListItem.StartTime]</param>
		<param name="label4">$INFO[ListItem.EndTime]</param>
		<param name="focused">false</param>
		<definition>
			<control type="group">
        <top>26</top>
        <left>20</left>
				<width>430</width>
				<height>300</height>
				<control type="image">
					<texture border="20" colordiffuse="66000000">masks/radius_20.png</texture>
				</control>
				<control type="image">
					<texture border="20" colordiffuse="$VAR[FocusColorTheme]">masks/radius_20.png</texture>
					<visible>$PARAM[focused] + Control.HasFocus($PARAM[list_id])</visible>
					<include condition="$PARAM[focused]">Animation_FocusTextureFade</include>
				</control>
				<control type="image">
          <centertop>25%</centertop>
          <centerleft>50%</centerleft>
          <width>129</width>
          <height>93</height>
					<texture align="center" aligny="top" fallback="DefaultTVShows.png" background="true">$PARAM[icon]</texture>
					<aspectratio>keep</aspectratio>
				</control>
				<control type="group">
					<visible>$PARAM[focused] + Control.HasFocus($PARAM[list_id])</visible>
					<control type="image">
						<right>20</right>
						<top>20</top>
						<width>35</width>
						<height>35</height>
						<texture colordiffuse="$VAR[FocusedTextColorVar]">$VAR[WallWatchedIconVar]</texture>
					</control>
					<control type="label">
						<centerleft>50%</centerleft>
						<top>120</top>
						<width>360</width>
						<height>75</height>
						<align>center</align>
						<aligny>center</aligny>
						<label>[LIGHT]$PARAM[label][/LIGHT]</label>
						<scroll>$PARAM[focused] + Control.HasFocus($PARAM[list_id])</scroll>
						<scrollspeed>125</scrollspeed>
						<font>font25_title</font>
						<textcolor>$VAR[FocusedTextColorVar]</textcolor>
						<selectedcolor>$VAR[FocusedTextColorVar]</selectedcolor>
					</control>
					<control type="label">
						<centerleft>50%</centerleft>
						<top>150</top>
						<width>360</width>
						<height>75</height>
						<align>center</align>
						<aligny>center</aligny>
						<label>$PARAM[label2]</label>
						<scroll>$PARAM[focused] + Control.HasFocus($PARAM[list_id])</scroll>
						<scrollspeed>125</scrollspeed>
						<font>font25</font>
						<textcolor>$VAR[FocusedTextColorVar]</textcolor>
						<selectedcolor>$VAR[FocusedTextColorVar]</selectedcolor>
					</control>
					<control type="label">
						<centerleft>-13%</centerleft>
						<top>187</top>
						<width>360</width>
						<height>75</height>
						<align>right</align>
						<aligny>center</aligny>
						<label>$PARAM[label3]</label>
						<scroll>$PARAM[focused] + Control.HasFocus($PARAM[list_id])</scroll>
						<scrollspeed>125</scrollspeed>
						<font>font25</font>
						<textcolor>$VAR[FocusedTextColorVar]</textcolor>
						<selectedcolor>$VAR[FocusedTextColorVar]</selectedcolor>
						<visible>!Integer.IsEqual(ListItem.Progress,0)</visible>
					</control>
					<control type="label">
						<centerleft>113%</centerleft>
						<top>187</top>
						<width>360</width>
						<height>75</height>
						<align>left</align>
						<aligny>center</aligny>
						<label>$PARAM[label4]</label>
						<scroll>$PARAM[focused] + Control.HasFocus($PARAM[list_id])</scroll>
						<scrollspeed>125</scrollspeed>
						<font>font25</font>
						<textcolor>$VAR[FocusedTextColorVar]</textcolor>
						<selectedcolor>$VAR[FocusedTextColorVar]</selectedcolor>
						<visible>!Integer.IsEqual(ListItem.Progress,0)</visible>
					</control>
					<control type="label">
						<centerleft>50%</centerleft>
						<top>187</top>
						<width>360</width>
						<height>75</height>
						<align>center</align>
						<aligny>center</aligny>
						<label>$INFO[ListItem.StartTime] - $INFO[ListItem.EndTime]</label>
						<scroll>$PARAM[focused] + Control.HasFocus($PARAM[list_id])</scroll>
						<scrollspeed>125</scrollspeed>
						<font>font25</font>
						<textcolor>$VAR[FocusedTextColorVar]</textcolor>
						<selectedcolor>$VAR[FocusedTextColorVar]</selectedcolor>
						<visible>Integer.IsEqual(ListItem.Progress,0)</visible>
					</control>
					<control type="label">
						<centerleft>50%</centerleft>
						<top>224</top>
						<width>365</width>
						<height>75</height>
						<align>center</align>
						<aligny>center</aligny>
						<label>$VAR[WidgetFocusedPVRNextProgrammeLabel]</label>
						<scroll>$PARAM[focused] + Control.HasFocus($PARAM[list_id])</scroll>
						<scrollspeed>125</scrollspeed>
						<font>font25</font>
						<textcolor>$VAR[FocusedTextColorVar]</textcolor>
						<selectedcolor>$VAR[FocusedTextColorVar]</selectedcolor>
					</control>
