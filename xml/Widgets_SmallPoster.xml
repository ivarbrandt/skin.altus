<?xml version="1.0" encoding="UTF-8"?>
<includes>

  <include name="WidgetListSmallPoster">
		<param name="onclick_condition">false</param>
		<definition>
			<include content="CategoryLabel">
				<param name="label">$PARAM[widget_header]</param>
				<param name="list_id" value="$PARAM[list_id]"/>
			</include>
			<include content="BusyListSpinner">
				<param name="list_id" value="$PARAM[list_id]"/>
			</include>
			<control type="fixedlist" id="$PARAM[list_id]">
				<top>107</top>
				<right>0</right>
				<left>45</left>
				<height>529</height>
				<focusposition>0</focusposition>
				<movement>5</movement>
				<onright>$PARAM[list_id]</onright>
				<orientation>horizontal</orientation>
				<animation condition="Window.IsVisible(1121) + Container($PARAM[list_id]).IsUpdating" reversible="true" pulse="true">
					<effect type="fade" start="100" end="80" time="700" tween="sine" easing="inout" />
					<effect type="fadediffuse" start="FFE9E9E9" end="FF777777" time="700" />
				</animation>
				<visible>Container($PARAM[list_id]).IsUpdating | Integer.IsGreater(Container($PARAM[list_id]).NumItems,0) | String.IsEqual(Window(Home).Property(altus.search.refreshing),true)</visible>
				<onclick condition="$PARAM[onclick_condition]">$PARAM[onclick_action]</onclick>
				<onfocus>ClearProperty(FlixWidget,Home)</onfocus>
				<onfocus>ClearProperty(FeatureWidgetFocused,Home)</onfocus>
				<onfocus>ClearProperty(altus_stacked_linked_list_id,home)</onfocus>
				<include content="WidgetListCommon">
					<param name="list_id" value="$PARAM[list_id]"/>
				</include>
				<itemlayout width="226" >
					<control type="group">
						<left>-20</left>
						<top>70</top>
						<include content="SmallPosterLayout">
							<param name="list_id" value="$PARAM[list_id]" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout width="226" infoupdate="30">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>-20</left>
						<top>70</top>
						<include content="SmallPosterLayout">
							<param name="focused" value="true" />
							<param name="list_id" value="$PARAM[list_id]" />
						</include>
						<include>VideoTrailerControl</include>
					</control>
				</focusedlayout>
				<content sortby="$PARAM[sortby]" sortorder="$PARAM[sortorder]" target="$PARAM[widget_target]" limit="$PARAM[limit]">$PARAM[content_path]</content>
			</control>
			<include content="WidgetLeftRightArrows">
				<param name="list_id" value="$PARAM[list_id]" />
				<param name="posy" value="158" />
			</include>
		</definition>
	</include>

	<include name="WidgetListSmallPosterStacked">
		<param name="onclick_condition">false</param>
		<definition>
			<include content="CategoryLabelWidget">
				<param name="label">$PARAM[widget_header]</param>
				<param name="list_id" value="$PARAM[list_id]"/>
				<param name="visible" value="false"/>
			</include>
			<include content="BusyListWidgetSpinner">
				<param name="list_id" value="$PARAM[list_id]"/>
				<param name="posy" value="97"/>
			</include>
			<control type="fixedlist" id="$PARAM[list_id]">
				<top>17</top>
				<right>0</right>
				<left>45</left>
				<height>529</height>
				<focusposition>0</focusposition>
				<movement>5</movement>
				<onright>$PARAM[list_id]</onright>
				<orientation>horizontal</orientation>
				<onclick condition="$PARAM[onclick_condition]">$PARAM[onclick_action]</onclick>
				<include content="FlixAnimations_Stacked">
				</include>
				<onfocus>SetProperty(altus_stacked_linked_list_id,$PARAM[parent_id],home)</onfocus>
				<onfocus>SetProperty(altus_child_id,$PARAM[child_id],home)</onfocus>
				<onfocus>ClearProperty(FlixWidget,Home)</onfocus>
				<onfocus>ClearProperty(FeatureWidgetFocused,Home)</onfocus>
				<onfocus>ClearProperty(altus_flix_linked_list_id,home)</onfocus>
				<include content="WidgetListCommonStacked">
					<param name="list_id" value="$PARAM[list_id]"/>
				</include>
				<itemlayout width="226" >
					<control type="group">
						<left>-20</left>
						<top>70</top>
						<include content="SmallPosterLayout">
							<param name="list_id" value="$PARAM[list_id]" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout width="226" infoupdate="30">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>-20</left>
						<top>70</top>
						<include content="SmallPosterLayout">
							<param name="focused" value="true" />
							<param name="list_id" value="$PARAM[list_id]" />
						</include>
						<include>VideoTrailerControl</include>
					</control>
				</focusedlayout>
				<content sortby="$PARAM[sortby]" sortorder="$PARAM[sortorder]" target="$PARAM[widget_target]" limit="$PARAM[limit]">$PARAM[content_path]</content>
			</control>
			<include content="WidgetLeftRightArrows">
				<param name="list_id" value="$PARAM[list_id]" />
				<param name="posy" value="158" />
			</include>
		</definition>
	</include>

</includes>
