					<content sortby="label" sortorder="ascending">$INFO[Container($PARAM[group_id]51).ListItem.FolderPath]</content>
				</control>
				<control type="list" id="$PARAM[group_id]53">
					<left>1380</left>
					<top>150</top>
					<width>460</width>
					<height>810</height>
					<onleft>SetFocus($PARAM[group_id]53,0,absolute),$PARAM[group_id]52</onleft>
