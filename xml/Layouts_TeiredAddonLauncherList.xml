<?xml version="1.0" encoding="UTF-8"?>
<includes>

  <include name="TieredAddonLauncherList">
    <param name="fallback_image">DefaultFolder.png</param>
    <definition>
			<control type="group" id="$PARAM[group_id]">
				<left>40</left>
				<control type="label">
					<top>-860</top>
					<left>0</left>
					<aligny>center</aligny>
					<width>1920</width>
					<font>font36_title</font>
					<textcolor>unfocused_text</textcolor>
					<label>[LIGHT]$PARAM[id][/LIGHT]</label>
					<visible>ControlGroup(400).HasFocus + [Control.HasFocus($PARAM[group_id]50) | Control.HasFocus($PARAM[group_id]51) | Control.HasFocus($PARAM[group_id]52) | Control.HasFocus($PARAM[group_id]53)]</visible>
					<animation effect="fade" time="200" tween="cubic" easing="out">VisibleChange</animation>
				</control>
				<!-- First Level List - Repositories -->
				<control type="list" id="$PARAM[group_id]50">
					<left>0</left>
					<top>150</top>
					<width>460</width>
					<height>810</height>
					<onleft>9000</onleft>
					<onright>$PARAM[group_id]51</onright>
					<pagecontrol>$PARAM[group_id]30</pagecontrol>
					<onclick condition="String.StartsWith(ListItem.Property(Addon.ID),repository)">ActivateWindow(addonbrowser,addons://$INFO[ListItem.Property(Addon.ID)]/,return)</onclick>
					<onclick condition="!String.StartsWith(ListItem.Property(Addon.ID),repository) + !ListItem.IsFolder">info</onclick>
					<onclick condition="ListItem.IsFolder">ActivateWindow(addonbrowser,$INFO[ListItem.FolderPath],return)</onclick>
					<visible>String.IsEqual(Container(9000).ListItem.Property(id),$PARAM[id])</visible>
					<scrolltime tween="cubic" easing="out">700</scrolltime>
					<include content="Visible_Right_Delayed">
						<param name="id" value="$PARAM[id]"/>
					</include>
					<itemlayout height="90" infoupdate="30">
						<control type="group">
							<left>0</left>
							<top>0</top>
							<control type="image">
								<left>25</left>
								<centertop>50%</centertop>
								<width>60</width>
								<height>60</height>
								<texture diffuse="masks/mainmenu-img.png" fallback="DefaultAddon.png">$INFO[ListItem.Icon]</texture>
								<aspectratio>keep</aspectratio>
							</control>
							<control type="textbox">
								<left>100</left>
								<aligny>center</aligny>
								<width>335</width>
								<font>font27</font>
								<textcolor>unfocused_text</textcolor>
								<label>$INFO[ListItem.Label]</label>
							</control>
						</control>
					</itemlayout>
					<focusedlayout height="90" infoupdate="30">
						<control type="group">
							<left>0</left>
							<top>0</top>
							<control type="image">
								<texture border="23" colordiffuse="$VAR[FocusColorTheme]">masks/radius_23.png</texture>
								<animation effect="fade" start="100" end="50" time="40" condition="Control.HasFocus($PARAM[group_id]51) | Control.HasFocus($PARAM[group_id]52) | Control.HasFocus($PARAM[group_id]53)">Conditional</animation>
								<visible>ControlGroup(400).HasFocus</visible>
							</control>
							<control type="image">
								<left>405</left>
								<top>25</top>
								<width>40</width>
								<height>40</height>
								<texture colordiffuse="$VAR[FocusedTextColorVar]">overlays/arrowright.png</texture>
								<visible>Control.HasFocus($PARAM[group_id]50) + Integer.IsGreater(Container($PARAM[group_id]51).NumItems,0)</visible>
							</control>
							<control type="image">
								<left>25</left>
								<centertop>50%</centertop>
								<width>60</width>
								<height>60</height>
								<texture diffuse="masks/mainmenu-img.png" fallback="DefaultAddon.png">$INFO[ListItem.Icon]</texture>
								<aspectratio>keep</aspectratio>
								<visible>!Control.HasFocus($PARAM[group_id]50) | !String.IsEmpty(ListItem.Property(Addon.ID))</visible>
							</control>
							<control type="image">
								<left>25</left>
								<centertop>50%</centertop>
								<width>60</width>
								<height>60</height>
								<texture diffuse="masks/mainmenu-img.png" colordiffuse="$VAR[FocusedTextColorVar]" fallback="DefaultAddon.png">$INFO[ListItem.Icon]</texture>
								<aspectratio>keep</aspectratio>
								<visible>Control.HasFocus($PARAM[group_id]50) + [String.IsEmpty(ListItem.Property(Addon.ID)) | String.IsEqual(ListItem.Icon,DefaultAddon.png)]</visible>
							</control>
							<include content="AddonLauncherListFocusedLabels">
								<param name="focused_id" value="$PARAM[group_id]50"/>
							</include>
						</control>
					</focusedlayout>
					<content sortby="label" sortorder="ascending" target="$PARAM[container_target]">$PARAM[container_path]</content>
				</control>
