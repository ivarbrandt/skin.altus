					<visible allowhiddenfocus="true">[Control.HasFocus($PARAM[group_id]51) | Control.HasFocus($PARAM[group_id]52) | Control.HasFocus($PARAM[group_id]53)] + !String.IsEmpty(Container($PARAM[group_id]50).ListItem.FolderPath)</visible>
