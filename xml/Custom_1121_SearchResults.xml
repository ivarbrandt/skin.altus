						<height>75</height>
						<font>font32</font>
						<textcolor>unfocused_text</textcolor>
						<aligny>center</aligny>
						<align>center</align>
						<label>Type to search...</label>
					</control>

					<!-- Stacked display labels for the live input. Label A keeps
					     the cursor character at full width but transparent, so
					     it reserves layout. Label B's cursor is opaque and the
					     label has a fade pulse animation. The cursor character
					     occupies the same horizontal space in both labels, so
					     the surrounding text never jitters as B's opacity
					     cycles. Property split (before/after) lets us insert
					     differently-styled cursors at the same position. -->
					<control type="label">
						<visible>String.IsEqual(Window(home).Property(altus.search.mode),live) + !String.IsEmpty(Window(home).Property(altus.search.input))</visible>
						<left>40</left>
						<top>180</top>
						<width>428</width>
						<height>75</height>
						<font>font32</font>
						<textcolor>unfocused_text</textcolor>
						<aligny>center</aligny>
