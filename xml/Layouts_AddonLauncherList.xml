<?xml version="1.0" encoding="UTF-8"?>
<includes>

  <include name="AddonLauncherList">
    <param name="fallback_image">DefaultFolder.png</param>
    <param name="sortby">label</param>
    <param name="sortorder">ascending</param>
    <definition>
			<control type="group" id="$PARAM[group_id]">
				<left>0</left>
				<control type="label">
					<top>-860</top>
					<left>35</left>
					<aligny>center</aligny>
					<align>left</align>
					<font>font36_title</font>
					<textcolor>unfocused_text</textcolor>
					<label>[LIGHT]$PARAM[id][/LIGHT]</label>
					<visible>ControlGroup(400).HasFocus</visible>
					<animation effect="fade" time="200" tween="cubic" easing="out">VisibleChange</animation>
				</control>
				<include content="Visible_Right_Delayed">
					<param name="id" value="$PARAM[id]"/>
				</include>
				<visible>String.IsEqual(Container(9000).ListItem.Property(id),$PARAM[id])</visible>
				<control type="panel" id="$PARAM[group_id]50">
					<left>35</left>
					<top>150</top>
					<width>1920</width>
					<height>810</height>
					<onleft>9000</onleft>
					<onright>$PARAM[group_id]30</onright>
					<pagecontrol>$PARAM[group_id]30</pagecontrol>
					<onclick>info</onclick>
					<visible>Integer.IsGreater(Container($PARAM[group_id]50).NumItems,0) | Container($PARAM[group_id]50).IsUpdating</visible>
					<scrolltime tween="cubic" easing="out">500</scrolltime>
					<itemlayout height="120" width="470" infoupdate="30">
						<control type="image">
							<width>440</width>
							<height>90</height>
							<texture border="24" colordiffuse="66000000">masks/radius_23.png</texture>
						</control>
						<control type="image">
							<left>30</left>
							<top>20</top>
							<width>50</width>
							<height>50</height>
							<texture diffuse="lists/mainmenu-img.png" fallback="DefaultAddon.png">$INFO[ListItem.Icon]</texture>
							<aspectratio>keep</aspectratio>
						</control>
						<include content="AddonLauncherListUnfocusedLabels">
							<param name="width" value="305"/>
							<param name="top" value="-30"/>
            </include>
					</itemlayout>
					<focusedlayout height="120" width="470" infoupdate="30">
						<control type="image">
							<width>440</width>
							<height>90</height>
							<texture border="23" colordiffuse="$VAR[FocusColorTheme]">masks/radius_23.png</texture>
							<visible>ControlGroup(400).HasFocus</visible>
						</control>
						<control type="image">
							<left>30</left>
							<top>20</top>
							<width>50</width>
							<height>50</height>
							<texture diffuse="lists/mainmenu-img.png" fallback="DefaultAddon.png">$INFO[ListItem.Icon]</texture>
							<aspectratio>keep</aspectratio>
							<visible>!String.IsEmpty(ListItem.Property(Addon.ID)) | !Control.HasFocus($PARAM[group_id]51)</visible>
						</control>
						<control type="image">
							<left>30</left>
							<top>20</top>
							<width>50</width>
							<height>50</height>
							<texture diffuse="lists/mainmenu-img.png" fallback="DefaultAddon.png">$INFO[ListItem.Icon]</texture>
							<aspectratio>keep</aspectratio>
							<visible>[String.IsEmpty(ListItem.Property(Addon.ID)) | String.IsEqual(ListItem.Icon,DefaultAddon.png)] + Control.HasFocus($PARAM[group_id]50)</visible>
						</control>
						<include content="AddonLauncherListFocusedLabels">
              <param name="focused_id" value="$PARAM[group_id]50"/>
							<param name="width" value="305"/>
							<param name="top" value="-30"/>
            </include>
					</focusedlayout>
					<content sortby="$PARAM[sortby]" sortorder="$PARAM[sortorder]" target="$PARAM[container_target]">$PARAM[container_path]</content>
				</control>
				<include content="AddonsListScrollBar">
          <param name="scrollbar_panel_id" value="$PARAM[group_id]30"/>
          <param name="scrollbar_panel_id2" value="$PARAM[group_id]50"/>
        </include>
			</control>
		</definition>
	</include>

</includes>