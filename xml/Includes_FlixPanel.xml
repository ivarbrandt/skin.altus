						<control type="textbox">
							<align>left</align>
							<height max="300">auto</height>
							<label>$VAR[EpisodeTitle]</label>
							<font>font27</font>
							<textcolor>unfocused_text</textcolor>
							<scroll>true</scroll>
							<scrollspeed>150</scrollspeed>
							<visible>$EXP[isEpisode]</visible>
						</control>
						<control type="textbox">
