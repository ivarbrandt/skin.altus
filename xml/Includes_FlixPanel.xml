<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include name="PlotHeight_1080_FontSize_Default">
		<height max="335">auto</height>
	</include>
	<include name="PlotHeight_4K_FontSize_Default">
		<height max="330">auto</height>
	</include>
	<include name="PlotHeight_1080_FontSize_Large">
		<height max="297">auto</height>
	</include>
	<include name="PlotHeight_4K_FontSize_Large">
		<height max="297">auto</height>
	</include>
	<include name="PlotHeight_51_FontSize_Default">
		<height max="78">auto</height>
	</include>
	<include name="PlotHeight_51_FontSize_Large">
		<height max="87">auto</height>
	</include>
	<include name="Flix_Font_Default">
		<font>font27_plot</font>
	</include>
	<include name="Flix_Font_Large">
		<font>font32</font>
	</include>
	<include name="FlixPanel">
		<definition>
			<control type="group">
				<left>77</left>
				<right>77</right>
				<top>-70</top>
				<visible>[$EXP[isWall] + Skin.HasSetting(Enable.500Info)] | [$EXP[isLandscapeWall] + Skin.HasSetting(Enable.501Info)]</visible>
				<control type="grouplist">
					<top>960</top>
					<orientation>vertical</orientation>
					<align>right</align>
					<itemgap>0</itemgap>
					<include condition="!String.IsEmpty(Skin.String(valid_api_key))" content="HorizontalRatings">
						<param name="align" value="center"/>
					</include>
					<control type="label">
						<align>center</align>
						<height>35</height>
						<label>$VAR[VideoInfoPanelTop]</label>
						<include condition="String.IsEqual(Skin.String(FontSizeSetting),0)">Flix_Font_Default</include>
						<include condition="String.IsEqual(Skin.String(FontSizeSetting),1)">Flix_Font_Large</include>
						<textcolor>$VAR[FocusColorTheme]</textcolor>
						<scroll>true</scroll>
						<scrollspeed>150</scrollspeed>
					</control>
					<control type="textbox">
						<include condition="String.IsEqual(Skin.String(FontSizeSetting),0)">PlotHeight_51_FontSize_Default</include>
						<include condition="String.IsEqual(Skin.String(FontSizeSetting),1)">PlotHeight_51_FontSize_Large</include>
						<bottom>70</bottom>
						<label>$VAR[RI_Plot]</label>
						<include condition="String.IsEqual(Skin.String(FontSizeSetting),0)">Flix_Font_Default</include>
						<include condition="String.IsEqual(Skin.String(FontSizeSetting),1)">Flix_Font_Large</include>
						<textcolor>unfocused_text</textcolor>
						<align>center</align>
						<autoscroll delay="10000" time="5000" repeat="10000">Skin.HasSetting(autoscroll)</autoscroll>
						<visible>!String.IsEqual(Container.PluginName,plugin.program.openwizard) + [String.IsEqual(Container.Viewmode,$LOCALIZE[311022]) | String.IsEqual(Container.Viewmode,$LOCALIZE[311023])]</visible>
					</control>
				</control>
			</control>
			<!-- <control type="image">
				<left>1550</left>
				<top>70</top>
				
				<height>174</height>
				<texture>$INFO[$PARAM[infolabel_prefix]ListItem.Studio,resource://resource.images.studios.coloured/,.png]</texture>
				<aspectratio align="left" aligny="center">keep</aspectratio>
				<visible>!Control.IsVisible(50) + !String.IsEmpty($PARAM[infolabel_prefix]ListItem.Studio)</visible>
			</control> -->
		</definition>
	</include>

	<include name="PlotBox">
		<control type="textbox">
			<height max="$PARAM[max_height]">auto</height>
			<font>font27</font>
			<textcolor>unfocused_text</textcolor>
			<align>left</align>
			<label>$VAR[RI_Plot]</label>
			<autoscroll delay="$PARAM[delay_repeat]" time="1700" repeat="$PARAM[delay_repeat]">Skin.HasSetting(autoscroll)</autoscroll>
			<visible>$PARAM[visible]</visible>
		</control>
	</include>

