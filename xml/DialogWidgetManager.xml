						<control type="image">
							<left>25</left>
							<top>17</top>
							<width>30</width>
							<height>30</height>
							<texture diffuse="lists/mainmenu-img.png" colordiffuse="unfocused_text">$VAR[WidgetManagerItemIcon]</texture>
