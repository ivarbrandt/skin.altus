				<control type="label">
					<left>20</left>
					<top>10</top>
					<height>40</height>
					<label>Sections</label>
					<font>font27_title</font>
					<textcolor>$VAR[FocusColorTheme]</textcolor>
					<visible>String.IsEmpty(Window.Property(submenu_mode))</visible>
				</control>
				<!-- Section label (submenu mode) -->
				<control type="label">
					<left>20</left>
					<top>10</top>
					<right>20</right>
					<height>40</height>
					<label>$INFO[Window.Property(submenu_header)]</label>
