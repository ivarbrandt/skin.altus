			<!-- Header -->
			<control type="label">
				<left>30</left>
				<right>30</right>
				<top>12</top>
				<height>70</height>
				<label>Widget Manager</label>
				<align>left</align>
				<aligny>center</aligny>
				<font>font36_title</font>
				<textcolor>unfocused_text</textcolor>
			</control>

			<!-- ═══════════════════════════════════════ -->
