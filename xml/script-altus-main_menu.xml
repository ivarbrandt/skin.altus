<?xml version="1.0" encoding="UTF-8"?>
<includes>
  <include name="MainMenuItems">
    <item>
      <label>Movies</label>
      <onclick>ActivateWindow(Videos,plugin://plugin.video.fenlight,return)</onclick>
      <property name="menu_id">$NUMBER[19101]</property>
      <property name="id">movies</property>
      <visible>!Skin.HasSetting(HomeMenuNoSection_1)</visible>
    </item>
    <item>
      <label>TV Shows</label>
      <onclick>ActivateWindow(Videos,plugin://plugin.video.fenlight/?mode=navigator.build_shortcut_folder_contents&amp;name=TV+Shows&amp;iconImage=tv,return)</onclick>
      <property name="menu_id">$NUMBER[19201]</property>
      <property name="id">movies</property>
      <visible>!Skin.HasSetting(HomeMenuNoSection_2)</visible>
    </item>
    <item>
      <label>Live TV</label>
      <onclick>ActivateWindow(TVChannels)</onclick>
      <property name="menu_id">$NUMBER[19301]</property>
      <property name="id">movies</property>
      <visible>!Skin.HasSetting(HomeMenuNoSection_15)</visible>
    </item>
    <item>
      <label>Addons</label>
      <onclick>ActivateWindow(AddonBrowser,addons://,return)</onclick>
      <property name="menu_id">$NUMBER[19401]</property>
      <property name="id">movies</property>
      <visible>!Skin.HasSetting(HomeMenuNoSection_14)</visible>
    </item>
    <item>
      <label>$LOCALIZE[8]</label>
      <onclick condition="!String.IsEmpty(Weather.Plugin) + String.IsEmpty(Window(Home).Property(weather_cycling))">SetProperty(weather_cycling,true,home)</onclick>
      <onclick condition="!String.IsEmpty(Weather.Plugin) + String.IsEmpty(Window(Home).Property(weather_cycling))">ReplaceWindow(Weather)</onclick>
      <onclick condition="!String.IsEmpty(Weather.Plugin)">Notification(Weather, Cycling to next location..., 2000)</onclick>
      <onclick condition="!String.IsEmpty(Weather.Plugin)">Weather.LocationNext</onclick>
      <onclick condition="String.IsEmpty(Weather.Plugin)">ReplaceWindow(servicesettings,weather)</onclick>
      <property name="menu_id">$NUMBER[15000]</property>
      <property name="id">weather</property>
      <visible>!Skin.HasSetting(HomeMenuNoSection_17)</visible>
    </item>
  </include>
</includes>