<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol>3</defaultcontrol>
	<backgroundcolor>background</backgroundcolor>
	<controls>
		<include>ZeroFadeBackground</include>
		<control type="group">
			<left>470</left>
			<include>OpenClose_Right</include>
			<control type="grouplist" id="5">
				<description>control area</description>
				<top>133</top>
				<left>20</left>
				<right>490</right>
				<bottom>37</bottom>
				<pagecontrol>60</pagecontrol>
				<onleft>3</onleft>
				<onright>60</onright>
				<onup>5</onup>
				<ondown>5</ondown>
			</control>
			<!-- <control type="image">
				<left>20</left>
				<top>130</top>
				<right>490</right>
				<height>3</height>
				<texture colordiffuse="$VAR[FocusColorTheme]" border="3">dialogs/separator-grey.png</texture>
			</control> -->
		</control>
		<control type="button" id="7">
			<description>Default Button</description>
			<include>DefaultSettingButton</include>
		</control>
		<control type="radiobutton" id="8">
			<description>Default RadioButton</description>
			<include>DefaultSettingButton</include>
		</control>
		<control type="spincontrolex" id="9">
			<description>Default SpinControlex</description>
			<include>DefaultSettingButton</include>
			<aligny>center</aligny>
		</control>
		<control type="sliderex" id="13">
			<description>Default Slider</description>
			<include>DefaultSettingButton</include>
			<aligny>center</aligny>
		</control>
		<control type="image" id="11">
			<description>separator image</description>
			<height>62</height>
			<texture />
		</control>
		<control type="label" id="14">
			<description>Default Label</description>
			<width>1450</width>
			<textoffsetx>0</textoffsetx>
			<top>0</top>
			<height>70</height>
			<label></label>
			<align>left</align>
			<aligny>center</aligny>
			<font>font40_title</font>
			<textcolor>$VAR[FocusColorTheme]</textcolor>
			
		</control>
		<control type="colorbutton" id="15">
			<description>Default ColorButton</description>
			<include>DefaultSettingButton</include>
		</control>
		<control type="group">
			<depth>DepthContentPanel</depth>
			<include>OpenClose_Left</include>
			<control type="grouplist" id="3">
				<description>button area</description>
				<left>40</left>
				<top>130</top>
				<width>410</width>
				<height>810</height>
				<usecontrolcoords>true</usecontrolcoords>
				<onleft>5</onleft>
				<onright>5</onright>
				<onup>3</onup>
				<ondown>20</ondown>
			</control>
			<control type="button" id="10">
				<description>Default Category Button</description>
				<left>0</left>
				<height>85</height>
				<width>410</width>
				<textoffsetx>50</textoffsetx>
				<aligny>center</aligny>
				<align>left</align>
				<font>font37</font>
				<texturefocus border="23" colordiffuse="$VAR[FocusColorTheme]">masks/radius_23.png</texturefocus>
				<texturenofocus />
			</control>
		</control>
		<control type="group">
			<right>0</right>
			<top>133</top>
			<bottom>0</bottom>
			<width>60</width>
			<control type="scrollbar" id="60">
				<right>-6</right>
				<top>0</top>
				<bottom>0</bottom>
				<width>12</width>
				<orientation>vertical</orientation>
				<texturesliderbackground />
				<animation effect="slide" end="6,0" time="300" tween="sine" easing="inout" condition="!Control.HasFocus(60)">conditional</animation>
				<onleft>5</onleft>
				<onright>5</onright>
				<animation effect="fade" start="0" end="100" time="200" delay="300">Visible</animation>
				<animation effect="fade" start="100" end="0" time="200">Hidden</animation>
				<animation effect="fade" start="0" end="100" delay="300" time="320">WindowOpen</animation>
				<animation effect="fade" start="100" end="0" time="150">WindowClose</animation>
				<hitrect x="0" y="0" w="60" h="100%" />
			</control>
		</control>
		<include content="TopBar">
			<param name="breadcrumbs_label" value="[COLOR unfocused_text]$LOCALIZE[5][/COLOR] » [COLOR unfocused_text]$INFO[Control.GetLabel(2)][/COLOR]" />
		</include>
		<!-- <include>BottomBar</include> -->
		<control type="group">
			<depth>DepthContentPanel</depth>
			<include>OpenClose_Left</include>
			<control type="radiobutton" id="20">
				<width>410</width>
				<left>40</left>
				<bottom>70</bottom>
				<height>90</height>
				<aligny>center</aligny>
				<onclick>SettingsLevelChange</onclick>
				<textoffsetx>100</textoffsetx>
				<textoffsety>0</textoffsety>
				<texturefocus border="23" colordiffuse="$VAR[FocusColorTheme]">masks/radius_23.png</texturefocus>
				<texturenofocus />
				<radioposx>40</radioposx>
				<radioposy>0</radioposy>
				<radiowidth>40</radiowidth>
				<radioheight>40</radioheight>
				<onleft>5</onleft>
				<onright>5</onright>
				<onup>3</onup>
				<ondown>3</ondown>
				<textcolor>unfocused_text</textcolor>
				<font>font32</font>
				<focusedcolor>$VAR[FocusedTextColorVar]</focusedcolor>
				<textureradioonfocus colordiffuse="$VAR[FocusedTextColorVar]">icons/settings.png</textureradioonfocus>
				<textureradioonnofocus colordiffuse="unfocused_text">icons/settings.png</textureradioonnofocus>
				<textureradioofffocus colordiffuse="$VAR[FocusedTextColorVar]">icons/settings.png</textureradioofffocus>
				<textureradiooffnofocus colordiffuse="unfocused_text">icons/settings.png</textureradiooffnofocus>
				<textureradioonfocus/>
				<textureradioonnofocus/>
				<textureradioofffocus/>
				<textureradiooffnofocus/>
			</control>
		</control>
		<control type="group">
			<include>OpenClose_Right</include>
			<control type="textbox" id="6">
				<description>description area</description>
				<left>1470</left>
				<top>105</top>
				<right>40</right>
				<height>940</height>
				<font>font27</font>
				<align>left</align>
				<aligny>center</aligny>
				<textcolor>unfocused_text</textcolor>
				<autoscroll time="3000" delay="5000" repeat="5000">true</autoscroll>
			</control>
		</control>
		<control type="label" id="2">
			<description>breadcrumbs label</description>
			<visible>False</visible>
		</control>
	</controls>
</window>
