<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol always="true">11</defaultcontrol>
	<controls>
		<control type="group">
			<depth>DepthOSD</depth>
			<animation effect="fade" start="0" end="100" time="400" tween="cubic" easing="inout">WindowOpen</animation>
			<animation effect="fade" start="100" end="0" time="400" tween="cubic" easing="inout">WindowClose</animation>
			<!-- Shift left when called from tvchannels (embedded look). Tune the -500 to taste. -->
			<animation effect="slide" start="0,0" end="892,0" time="0" condition="Window.IsVisible(tvchannels)">Conditional</animation>

			<!-- OSD video backdrop: only show outside tvchannels -->
			<control type="group">
				<animation effect="fade" start="0" end="100" time="100">WindowOpen</animation>
				<animation effect="fade" start="100" end="0" time="100">WindowClose</animation>
				<animation effect="fade" start="100" end="75" time="0" condition="true">Conditional</animation>
				<visible>!Window.IsActive(fullscreenvideo) + !Window.IsVisible(tvchannels)</visible>
				<include>ColoredBackgroundImages</include>
			</control>

			<animation effect="fade" start="100" end="0" time="200" tween="sine" condition="$EXP[infodialog_active]">Conditional</animation>

			<control type="group">
				<include condition="!Window.IsVisible(tvchannels)">OpenClose_Left</include>
				<!-- <include content="DialogBackgroundCommons">
					<param name="width" value="1375" />
					<param name="shade_right" value="430" />
					<param name="divider_left" value="945" />
					<param name="header_label" value="" />
					<param name="header_id" value="" />
					<param name="darken_bg" value="!Window.IsVisible(tvchannels)" />
				</include> -->
				<!-- <control type="image">
					<left>1375</left>
					<width>1</width>
					<texture colordiffuse="$VAR[FocusColorTheme]">masks/mainmenupanel_divider.png</texture>
				</control> -->
				<control type="image">
					<left>1000</left>
					<top>450</top>
					<width>320</width>
					<height>280</height>
					<aspectratio align="center" aligny="center">keep</aspectratio>
					<texture fallback="DefaultTVShows.png" >$INFO[Listitem.Icon]</texture>
					<visible>Control.HasFocus(11) + !Window.IsVisible(tvchannels)</visible>
				</control>
				<control type="fixedlist" id="11">
					<left>0</left>
					<top>105</top>
					<width>988</width>
					<bottom>40</bottom>
					<onleft>60</onleft>
					<onleft condition="Window.IsVisible(tvchannels)">close</onleft>
					<onleft condition="!Window.IsVisible(tvchannels)">60</onleft>
					<onright condition="Window.IsVisible(tvchannels)">close</onright>
					<onright condition="!Window.IsVisible(tvchannels)">60</onright>
					<onup>11</onup>
					<ondown>11</ondown>
					<pagecontrol>60</pagecontrol>
					<scrolltime tween="cubic" easing="out">500</scrolltime>
					<movement>5</movement>
					<focusposition>5</focusposition>
					<itemlayout height="72" width="988">
						<control type="image">
							<width>30</width>
							<right>40</right>
							<texture colordiffuse="$VAR[FocusColorTheme]">$VAR[WallWatchedIconVar]</texture>
							<aspectratio aligny="center">keep</aspectratio>
							<animation effect="fade" start="100" end="0" time="1733" tween="cubic" easing="in" pulse="true" condition="ListItem.HasTimer | ListItem.HasReminder">Conditional</animation>
						</control>
						<control type="label">
							<left>20</left>
							<top>0</top>
							<bottom>0</bottom>
							<width>120</width>
							<aligny>center</aligny>
							<font>font27</font>
							<textcolor>unfocused_text</textcolor>
							<label>$INFO[ListItem.StartTime]</label>
						</control>
						<control type="label">
							<left>180</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>90</right>
							<aligny>center</aligny>
							<font>font27</font>
							<textcolor>unfocused_text</textcolor>
							<label>$VAR[PVRListItemSubLabelFocused]</label>
						</control>
						<!-- <control type="label">
							<right>90</right>
							<top>0</top>
							<bottom>0</bottom>
							<width>120</width>
							<align>right</align>
							<aligny>center</aligny>
							<font>font13</font>
							<textcolor>grey</textcolor>
							<label>$INFO[ListItem.Duration, ,m]</label>
						</control> -->
					</itemlayout>
					<focusedlayout height="216" width="988">
						<control type="image">
							<bottom>0</bottom>
							<texture colordiffuse="99000000">colors/darkest.png</texture>
							<animation effect="fade" start="100" end="50" time="40" condition="!Control.HasFocus(11)">Conditional</animation>
							<visible>!Window.IsVisible(tvchannels)</visible>
						</control>
						<control type="image">
							<left>0</left>
							<top>0</top>
							<right>20</right>
							<bottom>144</bottom>
							<texture colordiffuse="$VAR[FocusColorTheme]">lists/52_pvr.png</texture>
							<animation effect="fade" start="100" end="50" time="40" condition="!Control.HasFocus(11)">Conditional</animation>
						</control>
						<control type="image">
							<height>1</height>
							<bottom>0</bottom>
							<texture colordiffuse="$VAR[FocusColorTheme]">masks/posterflowdivider.png</texture>
							<visible>!Window.IsVisible(tvchannels)</visible>
						</control>
						<control type="image">
							<width>30</width>
							<right>40</right>
							<bottom>144</bottom>
							<texture colordiffuse="$VAR[FocusedTextColorVar]">$VAR[WallWatchedIconVar]</texture>
							<aspectratio aligny="center">keep</aspectratio>
							<!-- <animation effect="fade" start="100" end="0" time="1733" tween="cubic" easing="in" pulse="true" condition="ListItem.HasTimer | ListItem.HasReminder">Conditional</animation> -->
						</control>
						<control type="label">
							<left>20</left>
							<top>10</top>
							<bottom>0</bottom>
							<width>120</width>
							<font>font27</font>
							<textcolor>$VAR[FocusedTextColorVar]</textcolor>
							<label>$INFO[ListItem.StartTime]</label>
						</control>
						<control type="label">
							<left>180</left>
							<top>10</top>
							<bottom>0</bottom>
							<right>90</right>
							<font>font27</font>
							<textcolor>$VAR[FocusedTextColorVar]</textcolor>
							<label>$VAR[PVRListItemSubLabelFocused]</label>
							<scroll>$PARAM[focused]</scroll>
							<scrollspeed>100</scrollspeed>
						</control>
						<!-- <control type="label">
							<right>90</right>
							<top>10</top>
							<bottom>0</bottom>
							<width>120</width>
							<align>right</align>
							<font>font13</font>
							<textcolor>$VAR[FocusedTextColorVar]</textcolor>
							<label>$INFO[ListItem.Duration, ,m]</label>
						</control> -->
						<control type="textbox">
							<left>20</left>
							<top>80</top>
							<right>20</right>
							<bottom>6</bottom>
							<font>font23</font>
							<textcolor>unfocused_text</textcolor>
							<label>$INFO[ListItem.Plot]</label>
							<autoscroll time="3000" delay="4000" repeat="5000">Skin.HasSetting(autoscroll)</autoscroll>
							<visible>!String.IsEmpty(ListItem.Plot)</visible>
						</control>
					</focusedlayout>
				</control>

				<control type="scrollbar" id="60">
					<left>0</left>
					<top>0</top>
					<width>8</width>
					<bottom>0</bottom>
					<onleft>11</onleft>
					<onright>11</onright>
					<texturesliderbackground />
					<animation effect="fade" time="300" start="0" end="100" tween="cubic" easing="inout">VisibleChange</animation>
					<visible>Control.HasFocus(60) | Container.Scrolling</visible>
				</control>
			</control>

			<control type="group">
				<include>Animation_TopSlide</include>
				<visible>!Window.IsVisible(tvchannels)</visible>
				<top>15</top>
				<control type="label" id="2">
					<description>header label</description>
					<textoffsetx>40</textoffsetx>
					<width>1300</width>
					<height>70</height>
					<font>font45</font>
					<aligny>center</aligny>
					<label>$LOCALIZE[19069]$INFO[Container(11).ListItem.StartDate, - ]</label>
					<textcolor>unfocused_text</textcolor>
					<shadowcolor>black</shadowcolor>
				</control>
			</control>
		</control>
	</controls>
</window>
