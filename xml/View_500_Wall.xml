					<top>0</top>
					<include content="PosterLayout">
						<param name="focused" value="true" />
					</include>
					<include>WallTimer</include>
					<include>FocusBounce</include>
					<include>VideoTrailerControl</include>
				</control>
			</focusedlayout>
		</definition>
	</include>

