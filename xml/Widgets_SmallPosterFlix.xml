<?xml version="1.0" encoding="UTF-8"?>
<includes>

  <include name="WidgetListSmallPosterFlix">
		<param name="onclick_condition">false</param>
		<definition>
			<include content="CategoryLabel">
				<param name="label">$PARAM[widget_header]</param>
				<param name="list_id" value="$PARAM[list_id]"/>
				<param name="flix_slide" value="523"/>
			</include>
			<include content="BusyListSpinner">
				<param name="list_id" value="$PARAM[list_id]"/>
			</include>
			<control type="fixedlist" id="$PARAM[list_id]">
				<top>107</top>
				<right>0</right>
				<left>45</left>
				<height>971</height>
				<focusposition>0</focusposition>
				<movement>5</movement>
				<onright>$PARAM[list_id]</onright>
				<orientation>horizontal</orientation>
				<visible>Integer.IsGreater(Container($PARAM[list_id]).NumItems,0) | Container($PARAM[list_id]).IsUpdating</visible>
				<onfocus>SetProperty(FlixWidget,true,Home)</onfocus>
				<onfocus>SetProperty(altus_flix_linked_list_id,$PARAM[parent_id],home)</onfocus>
				<onfocus>ClearProperty(altus_stacked_linked_list_id,home)</onfocus>
				<onfocus>ClearProperty(FeatureWidgetFocused,Home)</onfocus>
				<onclick condition="$PARAM[onclick_condition]">$PARAM[onclick_action]</onclick>
				<animation effect="slide" start="0,0" end="0,523" time="400" tween="quadratic" condition="Control.HasFocus($PARAM[list_id])">Conditional</animation>
				<include content="WidgetListCommon">
					<param name="list_id" value="$PARAM[list_id]"/>
				</include>
				<itemlayout width="226" >
					<control type="image">
						<left>0</left>
						<top>386</top>
						<width>204</width>
						<height>306</height>
						<texture flipy="true" diffuse="masks/smallposter.png" colordiffuse="4DFFFFFF" background="true">$VAR[FlixPosterVar]</texture>
						<aspectratio scalediffuse="false">scale</aspectratio>
						<visible>!Control.HasFocus($PARAM[list_id]) + ![$EXP[dialog_visible] + !String.IsEmpty(Window(Home).Property(FlixWidget))]</visible>
					</control>
					<control type="group">
						<left>-20</left>
						<top>70</top>
						<include content="SmallPosterLayout">
							<param name="list_id" value="$PARAM[list_id]" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout width="226" infoupdate="30">
					<control type="image">
						<left>0</left>
						<top>386</top>
						<width>204</width>
						<height>306</height>
						<texture flipy="true" diffuse="masks/smallposter.png" colordiffuse="4DFFFFFF" background="true">$VAR[FlixPosterVar]</texture>
						<aspectratio scalediffuse="false">scale</aspectratio>
						<visible>!Control.HasFocus($PARAM[list_id]) + ![$EXP[dialog_visible] + !String.IsEmpty(Window(Home).Property(FlixWidget))]</visible>
					</control>
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>-20</left>
						<top>70</top>
						<include content="SmallPosterLayout">
							<param name="focused" value="true" />
							<param name="list_id" value="$PARAM[list_id]" />
						</include>
						<include>VideoTrailerControl</include>
					</control>
				</focusedlayout>
				<content sortby="$PARAM[sortby]" sortorder="$PARAM[sortorder]" target="$PARAM[widget_target]" limit="$PARAM[limit]">$PARAM[content_path]</content>
			</control>
			<include content="WidgetLeftRightArrows">
				<param name="list_id" value="$PARAM[list_id]" />
				<param name="visible" value="Control.HasFocus($PARAM[list_id]) | String.IsEmpty(Window(Home).Property(FlixWidget))" />
				<param name="posy" value="-280" />
				<param name="slide_end" value="525" />
			</include>
			<include content="LabelSpacer">
        <param name="label"></param>
        <param name="list_id" value="$PARAM[list_id]"/>
        <param name="visible" value="Control.HasFocus($PARAM[list_id]) + String.EndsWith(Window(Home).Property(altus_saved_list_id),11)"/>
			</include>
			<include content="LabelSpacer2">
        <param name="label"></param>
        <param name="list_id" value="$PARAM[list_id]"/>
        <param name="visible" value="Control.HasFocus($PARAM[list_id]) + !String.EndsWith(Window(Home).Property(altus_saved_list_id),11)"/>
			</include>
		</definition>
	</include>

	<include name="WidgetListSmallPosterFlixStacked">
		<param name="onclick_condition">false</param>
		<definition>
			<include content="BusyListWidgetSpinner">
				<param name="list_id" value="$PARAM[list_id]"/>
				<param name="posy" value="97"/>
			</include>
			<include content="CategoryLabelFlix">
				<param name="widget_header">$PARAM[widget_header]</param>
				<param name="list_id" value="$PARAM[list_id]"/>
				<param name="flix_slide" value="525"/>
			</include>
			<control type="fixedlist" id="$PARAM[list_id]">
				<top>17</top>
				<right>0</right>
				<left>45</left>
				<height>1062</height>
				<focusposition>0</focusposition>
				<movement>5</movement>
				<onright>$PARAM[list_id]</onright>
				<orientation>horizontal</orientation>
				<onclick condition="$PARAM[onclick_condition]">$PARAM[onclick_action]</onclick>
				<onfocus>SetProperty(FlixWidget,true,Home)</onfocus>
				<onfocus>SetProperty(altus_flix_linked_list_id,$PARAM[parent_id],home)</onfocus>
				<onfocus>SetProperty(altus_stacked_linked_list_id,$PARAM[parent_id],home)</onfocus>
				<onfocus>ClearProperty(FeatureWidgetFocused,Home)</onfocus>
				<animation effect="slide" start="0,0" end="0,560" time="400" tween="quadratic" condition="Control.HasFocus($PARAM[list_id])" reversible="true">Conditional</animation>
				<include content="WidgetListCommonStacked">
					<param name="list_id" value="$PARAM[list_id]"/>
				</include>
				<itemlayout width="226" >
					<control type="image">
						<left>0</left>
						<top>441</top>
						<width>204</width>
						<height>306</height>
						<texture flipy="true" diffuse="masks/smallposter.png" colordiffuse="4DFFFFFF" background="true">$VAR[FlixPosterVar]</texture>
						<aspectratio scalediffuse="false">scale</aspectratio>
						<visible>!Control.HasFocus($PARAM[list_id]) + ![$EXP[dialog_visible] + !String.IsEmpty(Window(Home).Property(FlixWidget))]</visible>
					</control>
					<control type="group">
						<left>-20</left>
						<top>125</top>
						<include content="SmallPosterLayout">
							<param name="list_id" value="$PARAM[list_id]" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout width="226" infoupdate="30">
					<control type="image">
						<left>0</left>
						<top>441</top>
						<width>204</width>
						<height>306</height>
						<texture flipy="true" diffuse="masks/smallposter.png" colordiffuse="4DFFFFFF" background="true">$VAR[FlixPosterVar]</texture>
						<aspectratio scalediffuse="false">scale</aspectratio>
						<visible>!Control.HasFocus($PARAM[list_id]) + ![$EXP[dialog_visible] + !String.IsEmpty(Window(Home).Property(FlixWidget))]</visible>
					</control>
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>-20</left>
						<top>125</top>
						<include content="SmallPosterLayout">
							<param name="focused" value="true" />
							<param name="list_id" value="$PARAM[list_id]" />
						</include>
						<include>VideoTrailerControl</include>
					</control>
				</focusedlayout>
				<content sortby="$PARAM[sortby]" sortorder="$PARAM[sortorder]" target="$PARAM[widget_target]" limit="$PARAM[limit]">$PARAM[content_path]</content>
			</control>
			<include content="WidgetLeftRightArrows">
				<param name="list_id" value="$PARAM[list_id]" />
				<param name="posy" value="-311" />
				<param name="slide_end" value="555" />
			</include>
			<include content="LabelSpacer">
        <param name="label"></param>
        <param name="spacer_height">167</param>
        <param name="list_id" value="$PARAM[list_id]"/>
        <param name="visible" value="Control.HasFocus($PARAM[list_id])"/>
			</include>
		</definition>
	</include>

</includes>
