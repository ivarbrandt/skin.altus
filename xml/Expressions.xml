<?xml version="1.0" encoding="UTF-8"?>
<includes>

  <expression name="isPlugin">String.StartsWith(Container.FolderPath,plugin://)</expression>
  <expression name="isContent">String.IsEqual(ListItem.DBType,movie) | String.IsEqual(ListItem.DBType,tvshow) | String.IsEqual(ListItem.DBType,episode) | String.IsEqual(ListItem.DBType,season)</expression>
  <expression name="isMovie">String.IsEqual(ListItem.DBType,movie)</expression>
  <expression name="isVideo">String.IsEqual(ListItem.DBType,video)</expression>
  <expression name="isTVShow">String.IsEqual(ListItem.DBType,tvshow)</expression>
  <expression name="isSeason">String.IsEqual(ListItem.DBType,season)</expression>
  <expression name="isSet">String.IsEqual(ListItem.DBType,set)</expression>
  <expression name="isEpisode">String.IsEqual(ListItem.DBType,episode)</expression>
  <expression name="isMV">String.IsEqual(ListItem.DBType,musicvideo)</expression>
  <expression name="isArtist">String.IsEqual(ListItem.DBType,artist)</expression>
  <expression name="isAlbum">String.IsEqual(ListItem.DBType,album)</expression>
  <expression name="isSong">String.IsEqual(ListItem.DBType,song)</expression>
  <expression name="noDBType">String.IsEmpty(ListItem.DBType)</expression>

  <expression name="isList">String.IsEqual(Container.Viewmode,$LOCALIZE[535])</expression>
  <expression name="isPosterFlow">String.IsEqual(Container.Viewmode,$LOCALIZE[310981])</expression>
  <expression name="isIconWall">String.IsEqual(Container.Viewmode,$LOCALIZE[31099])</expression>
  <expression name="isSlide">String.IsEqual(Container.Viewmode,$LOCALIZE[31100])</expression>
  <expression name="isPosterInfo">String.IsEqual(Container.Viewmode,$LOCALIZE[31101])</expression>
  <expression name="isLandscapeInfo">String.IsEqual(Container.Viewmode,$LOCALIZE[311012])</expression>
  <expression name="isFlixInfo">String.IsEqual(Container.Viewmode,$LOCALIZE[31107])</expression>
  <expression name="isWall">String.IsEqual(Container.Viewmode,$LOCALIZE[311022])</expression>
  <expression name="isLandscapeWall">String.IsEqual(Container.Viewmode,$LOCALIZE[311023])</expression>
  <expression name="isSeasonView">String.IsEqual(Container.Viewmode,$LOCALIZE[311024])</expression>

  <!-- EPISODE TYPE DISPLAY -->
  <expression name="ET_None">String.IsEqual(Skin.String(EpisodeTypeSetting),0)</expression>
  <expression name="ET_VI">String.IsEqual(Skin.String(EpisodeTypeSetting),1)</expression>
  <expression name="ET_HI">String.IsEqual(Skin.String(EpisodeTypeSetting),2)</expression>
  <expression name="ET_ART">String.IsEqual(Skin.String(EpisodeTypeSetting),3)</expression>
  <expression name="ET_VI+HI">String.IsEqual(Skin.String(EpisodeTypeSetting),4)</expression>
  <expression name="ET_VI+ART">String.IsEqual(Skin.String(EpisodeTypeSetting),5)</expression>
  <expression name="ET_HI+ART">String.IsEqual(Skin.String(EpisodeTypeSetting),6)</expression>
  <expression name="ET_All">String.IsEqual(Skin.String(EpisodeTypeSetting),7)</expression>
  <expression name="ET_VerticalIP">[$EXP[ET_VI] | $EXP[ET_VI+HI] | $EXP[ET_VI+ART] | $EXP[ET_All]]</expression>
  <expression name="ET_HorizontalIP">[$EXP[ET_HI] | $EXP[ET_VI+HI] | $EXP[ET_HI+ART] | $EXP[ET_All]]</expression>
  <expression name="ET_Artwork">[$EXP[ET_ART] | $EXP[ET_VI+ART] | $EXP[ET_HI+ART] | $EXP[ET_All]]</expression>

  <expression name="infodialog_active">Window.IsActive(musicinformation) | Window.IsActive(songinformation) | Window.IsActive(movieinformation) | Window.IsActive(addoninformation) | Window.IsActive(pvrguideinfo) | Window.IsActive(pvrrecordinginfo) | Window.IsActive(pictureinfo) | Window.IsVisible(script-embuary-video.xml) | Window.IsVisible(script-embuary-person.xml) | Window.IsVisible(script-embuary-image.xml)</expression>
	<expression name="sidebar_visible">ControlGroup(9000).HasFocus | Control.HasFocus(6130) | Control.HasFocus(6131)</expression>
	<expression name="dialog_visible">Window.IsVisible(shutdownmenu) | Window.IsVisible(contextmenu) | Window.IsVisible(1107)</expression>

  <expression name="hasMovieVI">$EXP[isMovie] + [!Skin.HasSetting(Disable.VI.Digital) | !Skin.HasSetting(Disable.VI.Mpaa) | !Skin.HasSetting(Disable.VI.Genre) | !Skin.HasSetting(Disable.VI.Director) | !Skin.HasSetting(Disable.VI.Runtime) | !Skin.HasSetting(Disable.VI.Endsat)]</expression>
  <expression name="hasTVShowVI">$EXP[isTVShow] + [!Skin.HasSetting(Disable.VI.Aired) | !Skin.HasSetting(Disable.VI.Mpaa) | !Skin.HasSetting(Disable.VI.Genre) | !Skin.HasSetting(Disable.VI.Director) | !Skin.HasSetting(Disable.VI.TotalSeasons) | !Skin.HasSetting(Disable.VI.TotalEpisodes) | !Skin.HasSetting(Disable.VI.EpDuration) | !Skin.HasSetting(Disable.VI.Status)]</expression>
  <expression name="hasSeasonVI">$EXP[isSeason] + [!Skin.HasSetting(Disable.VI.Aired) | !Skin.HasSetting(Disable.VI.Mpaa) | !Skin.HasSetting(Disable.VI.Genre) | !Skin.HasSetting(Disable.VI.EpDuration) | !Skin.HasSetting(Disable.VI.Endsat)]</expression>
  <expression name="hasEpisodeVI">$EXP[isEpisode] + [!Skin.HasSetting(Disable.VI.Aired) | !Skin.HasSetting(Disable.VI.Director) | !Skin.HasSetting(Disable.VI.Writer) | !Skin.HasSetting(Disable.VI.Runtime) | !Skin.HasSetting(Disable.VI.Endsat)]</expression>
  <expression name="hasAnyVI">$EXP[hasMovieVI] | $EXP[hasTVShowVI] | $EXP[hasSeasonVI] | $EXP[hasEpisodeVI]</expression>

  <expression name="showPlot">[String.IsEmpty(Skin.String(PlotSetting)) | String.IsEqual(Skin.String(PlotSetting),0)] | [String.IsEqual(Skin.String(PlotSetting),1) + !$EXP[isEpisode]]</expression>

  <expression name="hasWallWatchedIcon">ListItem.IsRecording | ListItem.HasReminder | ListItem.HasTimer | ListItem.IsCollection | ListItem.IsPlaying | Integer.IsGreater(ListItem.Playcount,0) | !Integer.IsEqual(Container.ListItem.Property(WatchedProgress),0)</expression>

</includes>
